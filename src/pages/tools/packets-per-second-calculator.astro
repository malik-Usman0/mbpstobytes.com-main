---
import Layout from '@theme/layouts/Layout.astro';
import RelatedTools from '@theme/components/RelatedTools.astro';

const title = 'Packets Per Second (PPS) Calculator – Mbps/Gbps to PPS';
const description =
  'Free PPS calculator with correct line-rate math — 1 Gbps at 64B = 1.49M PPS, not 1.95M. What packets per second means, what is good, and how to measure yours.';

const siteURL = 'https://www.mbpstobytes.com';
const pageURL = `${siteURL}/tools/packets-per-second-calculator/`;
const datePublished = '2026-07-14';

const faqs = [
  {
    question: 'What is a good PPS for networking?',
    answer:
      'It depends on the network. Home routers typically process 10,000–100,000 PPS comfortably. Small business networks need roughly 500,000–2 million PPS. Enterprise firewalls handle 1–10 million PPS, and carrier-grade hardware processes 100 million+ PPS using ASIC forwarding. As a rule of thumb: if your device\'s rated PPS is at least double your worst-case small-packet load, you have healthy headroom.',
  },
  {
    question: 'How many PPS is 1 Gbps?',
    answer:
      'At line rate with 64-byte frames, 1 Gbps = 1,488,095 PPS (≈1.49 Mpps), because each frame occupies 84 bytes on the wire including Ethernet overhead. With standard 1,500-byte MTU frames, 1 Gbps = 81,274 PPS. Calculators that ignore wire overhead report 1,953,125 and 83,333 respectively — those numbers overstate reality.',
  },
  {
    question: 'What is 14.88 Mpps?',
    answer:
      '14.88 Mpps (14,880,952 packets per second) is the line rate of a 10 Gbps Ethernet link carrying minimum-size 64-byte frames: 10,000,000,000 bits ÷ (84 bytes × 8 bits) = 14,880,952. It is the standard benchmark figure for "can this device forward 10 GbE at line rate," used in RFC 2544 testing.',
  },
  {
    question: 'Why do firewalls drop packets below their rated bandwidth?',
    answer:
      'Because bandwidth and PPS are separate limits. A firewall rated for 10 Gbps of throughput may only inspect ~1 million packets per second with deep inspection enabled. A flood of small 64-byte packets at just 0.7 Gbps already generates over 1 million PPS — hitting the packet-processing ceiling at 7% of the bandwidth rating. This is exactly why DDoS attacks use small packets.',
  },
  {
    question: 'How do I check my current PPS?',
    answer:
      'On Linux, run "sar -n DEV 1" (rxpck/s and txpck/s columns) or compare two readings of "ip -s link show". On Windows, open Performance Monitor and add the "Network Interface → Packets/sec" counter. Most router dashboards (pfSense, OPNsense, MikroTik, UniFi) graph PPS per interface out of the box.',
  },
  {
    question: 'Does packet size affect PPS?',
    answer:
      'Directly. PPS = link rate ÷ packet size on the wire, so smaller packets mean more packets per second for the same bandwidth. A 1 Gbps link carries about 18× more packets when they are 64-byte frames (1.49M PPS) than when they are 1,500-byte frames (81K PPS). That is why small-packet workloads like VoIP, gaming, and DNS stress hardware far more than file transfers.',
  },
  {
    question: 'Is PPS the same as throughput?',
    answer:
      'No. Throughput measures bits delivered per second (Mbps/Gbps); PPS counts individual packets processed per second. A device must do routing lookups, ACL checks, and forwarding decisions once per packet regardless of its size — so two traffic streams with identical Mbps can place wildly different loads on hardware depending on packet size.',
  },
  {
    question: 'Why is my real PPS lower than the calculator shows?',
    answer:
      'The calculator gives the theoretical ceiling of the link itself. Real hardware may cap out earlier: CPU-based routers saturate a core around 200K–500K PPS with the standard kernel stack, NIC interrupt handling adds limits, and every inspection feature (NAT, IPS, QoS) costs per-packet processing. If measured PPS plateaus while bandwidth is free, you have found your device\'s packet-processing limit.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Converters & Tools', item: `${siteURL}/converters/` },
    { '@type': 'ListItem', position: 3, name: 'Packets Per Second Calculator', item: pageURL },
  ],
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${pageURL}#webapplication`,
  name: 'Packets Per Second (PPS) Calculator',
  url: pageURL,
  description,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  browserRequirements: 'Requires JavaScript',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', '@id': `${siteURL}#organization` },
  inLanguage: 'en',
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': `${pageURL}#article`,
  headline: 'Packets Per Second (PPS): Calculator & Complete Guide',
  description,
  datePublished,
  dateModified: datePublished,
  author: { '@type': 'Organization', name: 'Mbps to Bytes Editorial Team', url: `${siteURL}/about-us/` },
  publisher: { '@type': 'Organization', '@id': `${siteURL}#organization` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageURL },
  image: `${siteURL}/images/og.png`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const toc = [
  ['#calculator', 'PPS Calculator'],
  ['#quick-answer', 'Quick Answer'],
  ['#what-is-pps', 'What Is PPS?'],
  ['#pps-vs-mbps', 'PPS vs Mbps'],
  ['#formula', 'The Formula (Done Right)'],
  ['#calculator-mistake', 'The Mistake Most PPS Calculators Make'],
  ['#line-rate-table', 'Line-Rate Reference Table'],
  ['#good-pps', "What's a Good PPS?"],
  ['#device-classes', 'PPS by Hardware Class'],
  ['#measure-pps', 'How to Measure Your Own PPS'],
  ['#ddos', 'Why DDoS Is Measured in PPS'],
  ['#faqs', 'FAQs'],
  ['#references', 'References'],
];
