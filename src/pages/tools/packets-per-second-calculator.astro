  <!-- Calculator Logic -->
  <script is:inline>
    const el = (id) => document.getElementById(id);
    const $rate = el("rate");
    const $rateUnit = el("rate-unit");
    const $pps = el("pps");
    const $psize = el("psize");
    const $mode = el("size-mode");
    const $modeHint = el("mode-hint");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $outLine = el("out-line");
    const $outNaive = el("out-naive");
    const $outMbps = el("out-mbps");
    const $outWire = el("out-wire");
    const $outPpm = el("out-ppm");

    let state = { lastEdited: "rate", decimals: 0 };

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const fmt = (n) => (Number.isFinite(n) ? Number(n.toFixed(state.decimals)).toLocaleString() : "—");
    const scaled = (pps) => {
      if (!Number.isFinite(pps)) return "—";
      if (pps >= 1_000_000) return (pps / 1_000_000).toFixed(2).replace(/\.00$/, "") + " Mpps";
      if (pps >= 10_000) return (pps / 1_000).toFixed(1).replace(/\.0$/, "") + " Kpps";
      return fmt(pps) + " PPS";
    };

    // On-wire bytes for line-rate math; naive bytes for comparison
    const wireBytes = () => {
      let size = num($psize.value);
      if (!Number.isFinite(size) || size <= 0) return { wire: NaN, naive: NaN };
      const mode = $mode.value;
      if (mode === "frame") {
        const frame = Math.max(64, size);
        return { wire: frame + 20, naive: size };
      }
      if (mode === "mtu") {
        const frame = Math.max(64, size + 18);
        return { wire: frame + 20, naive: size };
      }
      return { wire: size, naive: size };
    };

    const hints = {
      frame: "64B frame → 84B on the wire (preamble 8B + frame 64B + inter-frame gap 12B). Frames below 64B are padded per the Ethernet standard.",
      mtu: "1500B MTU → 1518B frame (+14B header, +4B FCS) → 1538B on the wire with preamble and inter-frame gap.",
      raw: "No overhead added — matches naive calculators. Use only for non-Ethernet links or quick comparisons.",
    };

    const render = () => {
      const { wire, naive } = wireBytes();
      $modeHint.textContent = hints[$mode.value];

      let bps, ppsLine;
      if (state.lastEdited === "rate") {
        const r = num($rate.value);
        bps = Number.isFinite(r) && $rate.value !== "" ? r * Number($rateUnit.value) * 1_000_000 : NaN;
        ppsLine = bps / (wire * 8);
        if (Number.isFinite(ppsLine)) $pps.value = Math.round(ppsLine).toString();
        else $pps.value = "";
      } else {
        const p = num($pps.value);
        ppsLine = Number.isFinite(p) && $pps.value !== "" ? p : NaN;
        bps = ppsLine * wire * 8;
        if (Number.isFinite(bps)) {
          const unitFactor = Number($rateUnit.value) * 1_000_000;
          $rate.value = Number((bps / unitFactor).toFixed(4)).toString();
        } else $rate.value = "";
      }

      const ppsNaive = bps / (naive * 8);
      const mbps = bps / 1_000_000;

      if (!Number.isFinite(ppsLine) || !Number.isFinite(bps)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$outLine, $outNaive, $outMbps, $outWire, $outPpm].forEach((o) => (o.textContent = "—"));
        return;
      }

      $resMain.textContent = fmt(ppsLine) + " PPS";
      $resSecondary.textContent = "≈ " + scaled(ppsLine) + ($mode.value === "raw" ? " (no overhead)" : " at line rate");
      $outLine.textContent = fmt(ppsLine);
      $outNaive.textContent = $mode.value === "raw" ? fmt(ppsNaive) + " (same)" : fmt(ppsNaive);
      $outMbps.textContent = mbps >= 1000 ? (mbps / 1000).toFixed(2).replace(/\.00$/, "") + " Gbps" : fmt(mbps) + " Mbps";
      $outWire.textContent = fmt(wire) + " B";
      $outPpm.textContent = fmt(ppsLine * 60);
      $decValue.textContent = state.decimals;
    };

    $rate.addEventListener("input", () => { state.lastEdited = "rate"; render(); });
    $rateUnit.addEventListener("change", render);
    $pps.addEventListener("input", () => { state.lastEdited = "pps"; render(); });
    $psize.addEventListener("input", render);
    $mode.addEventListener("change", render);

    document.querySelectorAll(".size-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        $psize.value = chip.dataset.size;
        render();
      });
    });

    $decMinus.addEventListener("click", () => { state.decimals = Math.max(0, state.decimals - 1); render(); });
    $decPlus.addEventListener("click", () => { state.decimals = Math.min(6, state.decimals + 1); render(); });

    $btnShare.addEventListener("click", async () => {
      const txt = `PPS: ${$rate.value} ${$rateUnit.options[$rateUnit.selectedIndex].text} @ ${$psize.value}B = ${$resMain.textContent} (line rate, overhead included). via mbpstobytes.com/tools/packets-per-second-calculator/`;
      try { await navigator.clipboard.writeText(txt); } catch (e) {}
    });

    $btnReload.addEventListener("click", () => window.location.reload());
    $btnClear.addEventListener("click", () => {
      $rate.value = "";
      $pps.value = "";
      state.lastEdited = "rate";
      render();
    });

    render();
  </script>
</Layout>
