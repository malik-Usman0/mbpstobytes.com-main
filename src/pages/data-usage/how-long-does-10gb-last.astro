  <!-- Allocator logic -->
  <script is:inline>
    const alRates = { social: 0.15, music: 0.1, sd: 0.7, hd: 2.5, call: 1 };
    const alState = { plan: 10, social: 1, music: 1, sd: 0, hd: 0.5, call: 0 };
    const $alDaily = document.getElementById("al-daily");
    const $alDays = document.getElementById("al-days");
    const $alBar = document.getElementById("al-bar");
    const $alNote = document.getElementById("al-note");

    const alRender = () => {
      const daily = Object.keys(alRates).reduce((s, k) => s + alRates[k] * alState[k], 0);
      const days = daily > 0 ? alState.plan / daily : Infinity;
      $alDaily.textContent = (daily >= 10 ? Math.round(daily) : (Math.round(daily * 10) / 10)) + " GB/day";
      $alDays.textContent = daily === 0 ? "forever" : days >= 30 ? "30+ days" : days >= 10 ? "~" + Math.round(days) + " days" : days >= 1 ? "~" + (Math.round(days * 2) / 2) + " days" : "<1 day";
      const pct = daily === 0 ? 100 : Math.min(100, (days / 30) * 100);
      $alBar.style.width = pct + "%";
      $alBar.className = "h-full rounded-full transition-all duration-500 bg-gradient-to-r " + (pct >= 95 ? "from-teal-400 to-teal-500" : pct >= 40 ? "from-amber-400 to-amber-500" : "from-rose-400 to-rose-500");
      let tail;
      if (daily === 0) tail = "no cellular habits selected — this plan only spends when you do.";
      else if (days >= 30) tail = "this mix fits the whole month with room to spare.";
      else if (days >= 14) tail = "half a month or better — one Wi-Fi habit swap likely makes it monthly.";
      else if (days >= 5) tail = "the classic capped-plan squeeze — the HD video line is almost always the fix.";
      else tail = "days, not weeks — at this pace consider an unlimited plan or move video to Wi-Fi.";
      const dTxt = daily >= 10 ? Math.round(daily) : Math.round(daily * 10) / 10;
      $alNote.innerHTML = `At <strong>${dTxt} GB/day, ${alState.plan} GB lasts ${$alDays.textContent.replace("~", "about ")}</strong> — ${tail}`;
    };

    const alActive2 = "px-3 py-1 rounded-full border-2 border-indigo-400 bg-white text-indigo-600 text-xs font-semibold";
    const alIdle2 = "px-3 py-1 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-xs font-semibold hover:bg-teal-100 transition-colors";
    const alActiveP = "px-4 py-1.5 rounded-full border-2 border-indigo-400 bg-white text-indigo-600 text-sm font-semibold";
    const alIdleP = "px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors";

    document.querySelectorAll(".al-p").forEach((chip) => {
      chip.addEventListener("click", () => {
        document.querySelectorAll(".al-p").forEach((c) => (c.className = "al-chip al-p " + alIdleP));
        chip.className = "al-chip al-p " + alActiveP;
        alState.plan = Number(chip.dataset.p);
        alRender();
      });
    });
    document.querySelectorAll(".al-a").forEach((chip) => {
      chip.addEventListener("click", () => {
        const act = chip.dataset.act;
        document.querySelectorAll(`.al-a[data-act="${act}"]`).forEach((c) => (c.className = "al-chip al-a " + alIdle2));
        chip.className = "al-chip al-a " + alActive2;
        alState[act] = Number(chip.dataset.v);
        alRender();
      });
    });
  </script>
