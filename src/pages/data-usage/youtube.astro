  <!-- Phone plan calculator logic -->
  <script is:inline>
    const ytState = { g: 2.3, h: 1 };
    const $ytTotal = document.getElementById("yt-total");
    const $ytDetail = document.getElementById("yt-detail");
    const $ytNote = document.getElementById("yt-note");
    const ytPlans = [[5, document.getElementById("yt-p5")], [15, document.getElementById("yt-p15")], [50, document.getElementById("yt-p50")]];
    const ytQName = { "0.5": "Data saver", "1.1": "720p", "2.3": "1080p", "9": "4K" };

    const ytFmtDays = (d) => {
      if (d >= 30) return "30+ days";
      if (d >= 10) return "~" + Math.round(d) + " days";
      if (d >= 1) return "~" + (Math.round(d * 2) / 2) + " days";
      return "<1 day";
    };

    const ytRender = () => {
      const perDay = ytState.g * ytState.h;
      const total = perDay * 30;
      $ytTotal.textContent = (total >= 100 ? Math.round(total) : Math.round(total * 10) / 10) + " GB";
      $ytDetail.textContent = `${ytQName[ytState.g]} · ${ytState.h} h/day · ~${ytState.g} GB/hour`;
      ytPlans.forEach(([gb, el]) => {
        const days = gb / perDay;
        el.textContent = ytFmtDays(days);
        el.className = "text-xl font-extrabold " + (days >= 30 ? "text-teal-600" : days >= 10 ? "text-amber-500" : "text-rose-500");
      });
      let tail;
      if (total <= 15) tail = "light enough to fit most phone plans — Data saver habits are how unlimited-feeling months happen.";
      else if (total <= 50) tail = "a mid-size phone plan's entire allowance — set the app's mobile preference to Data saver for the commute and save the quality for Wi-Fi.";
      else tail = "more than most phone plans on its own. Data saver mode turns the same habit into ~" + Math.round(0.5 * ytState.h * 30) + " GB.";
      $ytNote.innerHTML = `This habit costs <strong>~${Math.round(total)} GB a month on cellular</strong> — ${tail}`;
    };

    const ytActive = "px-4 py-1.5 rounded-full border-2 border-indigo-400 bg-white text-indigo-600 text-sm font-semibold";
    const ytIdle = "px-4 py-1.5 rounded-full border border-amber-200 bg-amber-50 text-amber-700 text-sm font-semibold hover:bg-amber-100 transition-colors";

    document.querySelectorAll(".yt-q").forEach((chip) => {
      chip.addEventListener("click", () => {
        document.querySelectorAll(".yt-q").forEach((c) => (c.className = "yt-chip yt-q " + ytIdle));
        chip.className = "yt-chip yt-q " + ytActive;
        ytState.g = Number(chip.dataset.g);
        ytRender();
      });
    });
    document.querySelectorAll(".yt-h").forEach((chip) => {
      chip.addEventListener("click", () => {
        document.querySelectorAll(".yt-h").forEach((c) => (c.className = "yt-chip yt-h " + ytIdle));
        chip.className = "yt-chip yt-h " + ytActive;
        ytState.h = Number(chip.dataset.h);
        ytRender();
      });
    });
  </script>
</Layout>
