                <svg class="w-5 h-5 text-gray-400 group-open:text-indigo-600 transform group-open:rotate-180 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed">{faq.answer}</div>
          </details>
        ))
      }
    </div>
  </section>

