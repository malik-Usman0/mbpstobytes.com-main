      },
      {
        name: 'Mbps vs MB/s Explained',
        url: '/learn/mbps-vs-mbps/',
        description: 'The other great unit trap — 8× apart, one letter apart.',
        icon: '🔤',
      },
    ]}
  />

  <!-- Decoder logic -->
  <script is:inline>
    const ddChips = document.querySelectorAll(".dd-chip");
    const $ddBox = document.getElementById("dd-box");
    const $ddWin = document.getElementById("dd-win");
    const $ddMac = document.getElementById("dd-mac");
    const $ddNote = document.getElementById("dd-note");

    const ddRender = (gb) => {
      const bytes = gb * 1e9;
      const gib = bytes / 1073741824;
      const trunc = (x) => Math.floor(x * 100) / 100; // Windows truncates its display
      const boxLabel = gb >= 1000 ? (gb / 1000) + " TB" : gb + " GB";
      let winNum, boxNum;
      let winLabel;
      if (gib >= 1024) {
        winNum = trunc(bytes / 1099511627776); boxNum = gb / 1000;
        winLabel = winNum + ' "TB"';
      } else {
        winNum = trunc(gib); boxNum = gb;
        winLabel = winNum + ' "GB"';
      }
      $ddBox.textContent = boxLabel;
      $ddWin.textContent = winLabel;
      $ddMac.textContent = boxLabel;
      const gapPct = (((boxNum - winNum) / boxNum) * 100).toFixed(1);
      $ddNote.textContent = `Same ${bytes.toLocaleString()} bytes in all three boxes. Difference between box and Windows: 0 bytes — ${gapPct}% of label.`;
    };

    ddChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        ddChips.forEach((c) => (c.className = "dd-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors"));
        chip.className = "dd-chip px-4 py-1.5 rounded-full border-2 border-indigo-300 bg-white text-indigo-600 text-sm font-semibold";
        ddRender(Number(chip.dataset.gb));
      });
    });
  </script>
</Layout>
