  <!-- Widget scripts -->
  <script is:inline>
    // Mini converter
    const $mvmMbps = document.getElementById("mvm-mbps");
    const $mvmMB = document.getElementById("mvm-mbytes");
    const mvmNum = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const mvmFmt = (n) => (Number.isFinite(n) ? Number(n.toFixed(4)).toString() : "");
    $mvmMbps.addEventListener("input", () => {
      const v = mvmNum($mvmMbps.value);
      $mvmMB.value = $mvmMbps.value === "" ? "" : mvmFmt(v / 8);
    });
    $mvmMB.addEventListener("input", () => {
      const v = mvmNum($mvmMB.value);
      $mvmMbps.value = $mvmMB.value === "" ? "" : mvmFmt(v * 8);
    });

    // Trap demo
    const $trapSize = document.getElementById("trap-size");
    const $trapSpeed = document.getElementById("trap-speed");
    const $trapWrong = document.getElementById("trap-wrong");
    const $trapRight = document.getElementById("trap-right");
    const $trapNote = document.getElementById("trap-note");
    const trapFmt = (sec) => {
      if (sec >= 3600) { const h = Math.floor(sec / 3600); const m = Math.round((sec % 3600) / 60); return `${h}h ${m}m`; }
      if (sec >= 90) { const m = Math.floor(sec / 60); const s = Math.round(sec % 60); return s ? `${m}m ${s}s` : `${m} minutes`; }
      return `${Math.round(sec)} seconds`;
    };
    const trapRender = () => {
      const mb = Number($trapSize.value);
      const mbps = Number($trapSpeed.value);
      const wrong = mb / mbps;            // treating Mbps as if it were MBps
      const right = (mb * 8) / mbps;      // correct
      $trapWrong.textContent = trapFmt(wrong);
      $trapRight.textContent = trapFmt(right);
      const diff = right - wrong;
      $trapNote.textContent = `The mistake makes every estimate exactly 8× too optimistic — here, ${trapFmt(diff)} of "where did my speed go?"`;
    };
    $trapSize.addEventListener("change", trapRender);
    $trapSpeed.addEventListener("change", trapRender);
    trapRender();
  </script>
