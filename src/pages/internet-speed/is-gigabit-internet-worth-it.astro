      },
      {
        name: 'Download Time Calculator',
        url: '/tools/download-time-calculator/',
        description: 'Any file, any speed — see the wait at your measured Mbps, not the advertised one.',
        icon: '⏱️',
      },
    ]}
  />

  <!-- Reality check logic -->
  <script is:inline>
    const rcChips = document.querySelectorAll(".rc-chip");
    const $rcName = document.getElementById("rc-name");
    const $rcVal = document.getElementById("rc-val");
    const $rcBar = document.getElementById("rc-bar");
    const $rcNote = document.getElementById("rc-note");

    const rcRender = (mbps, name) => {
      const pct = Math.round((mbps / 1000) * 100);
      $rcName.textContent = name;
      $rcVal.textContent = `~${mbps.toLocaleString()} Mbps`;
      $rcBar.style.width = pct + "%";
      const mbs = (mbps / 8).toFixed(mbps % 8 === 0 ? 0 : 1);
      let tail;
      if (mbps >= 900) {
        tail = "That's the wired ceiling — protocol overhead accounts for the rest. This is the one setup where gigabit delivers nearly everything you pay for.";
      } else if (mbps >= 700) {
        tail = "Close to the plan's potential — modern Wi-Fi near the router is the best wireless case. Downloads will feel dramatically fast.";
      } else if (mbps >= 500) {
        tail = "That's still " + mbs + " MB/s of real download speed, but it means a 500 Mbps plan would feel nearly identical on this device.";
      } else {
        tail = "At this point the plan tier barely matters — a 300 or 500 Mbps plan would deliver the same experience here. Fix the connection before buying bandwidth.";
      }
      $rcNote.innerHTML = `This setup typically delivers <strong>~${mbps.toLocaleString()} Mbps — ${pct}% of what you pay for</strong>. ${tail}`;
    };

    rcChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        rcChips.forEach((c) => (c.className = "rc-chip px-4 py-1.5 rounded-full border border-indigo-200 bg-indigo-50 text-indigo-700 text-sm font-semibold hover:bg-indigo-100 transition-colors"));
        chip.className = "rc-chip px-4 py-1.5 rounded-full border-2 border-indigo-400 bg-white text-indigo-600 text-sm font-semibold";
        rcRender(Number(chip.dataset.mbps), chip.dataset.name);
      });
    });
  </script>
</Layout>
