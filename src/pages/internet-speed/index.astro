---
import Layout from '@theme/layouts/Layout.astro';

const title = 'Internet Speed Guides – Is Your Plan Fast Enough?';
const description =
  'Honest, benchmark-backed verdicts on internet speeds: is 100 Mbps good, what each plan tier really handles, and how much speed your household actually needs.';

const siteURL = 'https://www.mbpstobytes.com';
const pageURL = `${siteURL}/internet-speed/`;

const articles = [
  {
    title: 'Internet Speed for Gaming: Why Ping Beats Bandwidth',
    url: '/internet-speed/for-gaming/',
    category: 'Use Cases',
    description: 'Games use 3–6 Mbps — milliseconds decide the rest. The ping/jitter/loss thresholds, a simulator that lets you feel latency, the real lag villains, and the honest list of where speed does matter.',
  },
  {
    title: 'Is Gigabit Internet Worth It? The 940 Mbps Reality Check',
    url: '/internet-speed/is-gigabit-internet-worth-it/',
    category: 'Plan Verdicts',
    description: 'You pay for 1,000 Mbps; wires deliver ~940 and Wi-Fi often far less. The interactive reality check, the three tests that justify the tier, and the cable-vs-fiber upload gap.',
  },
  {
    title: 'Is 500 Mbps Fast? The Last Tier Your Wi-Fi Can Actually Use',
    url: '/internet-speed/is-500-mbps-good/',
    category: 'Plan Verdicts',
    description: 'The in-between tier, decided honestly: 62.5 MB/s, twenty 4K streams\' worth — and the Wi-Fi ceiling argument that settles 500-vs-gigabit. With the interactive Tier Matchmaker.',
  },
  {
    title: 'Is 300 Mbps Good? What Upgrading From 100 Actually Buys',
    url: '/internet-speed/is-300-mbps-good/',
    category: 'Plan Verdicts',
    description: 'The upsell tier, priced honestly: downloads triple, streaming feels identical. Who genuinely needs it, who\'s wasting money, and the interactive download time machine.',
  },
  {
    title: 'Is 100 Mbps Good? The Honest Verdict for 2026',
    url: '/internet-speed/is-100-mbps-good/',
    category: 'Plan Verdicts',
    description: 'The FCC broadband floor, tested against real households — with a live stress-test tool, download-wait tables, and the upload trap cable providers don\'t mention.',
  },
];

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${pageURL}#collectionpage`,
  name: title,
  url: pageURL,
  description,
  hasPart: articles.map((a) => ({
    '@type': 'TechArticle',
    headline: a.title,
    url: `${siteURL}${a.url}`,
    description: a.description,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Internet Speed', item: pageURL },
  ],
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-400">
    <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <span class="text-gray-600 font-medium">Internet Speed</span>
  </nav>

  <div class="text-center max-w-3xl mx-auto mb-10">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 rounded-full mb-4">
      <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
      <span class="text-indigo-600 text-xs font-semibold uppercase tracking-wide">Speed Guides</span>
    </div>
    <h1 class="font-extrabold text-3xl md:text-4xl text-gray-900 tracking-tight">Is Your Internet Plan Actually Fast Enough?</h1>
    <p class="text-gray-500 text-base mt-4 leading-relaxed">
      Most "what speed do I need" advice comes from sites that earn a commission when you upgrade. These guides don't sell plans — they test each speed tier against published platform requirements (<a href="https://help.netflix.com/en/node/306" rel="noopener" target="_blank" class="text-indigo-600 hover:underline font-medium">Netflix</a>, Zoom) and the <a href="https://www.fcc.gov/consumers/guides/broadband-speed-guide" rel="noopener" target="_blank" class="text-indigo-600 hover:underline font-medium">FCC's broadband benchmarks</a>, tell you honestly where each tier breaks, and give you interactive tools to test your own household instead of taking anyone's word for it. Start with the <a href="/tools/bandwidth-calculator/" class="text-indigo-600 hover:underline font-medium">bandwidth calculator</a> if you want a number; start below if you're judging a specific plan.
    </p>
  </div>

  <div class="max-w-3xl mx-auto space-y-6">
    {
      articles.map((a) => (
        <a href={a.url} class="premium-card block p-8 group hover:shadow-lg transition-all duration-300">
          <p class="text-indigo-600 text-xs font-semibold uppercase tracking-wide mb-2">{a.category}</p>
          <h2 class="font-bold text-2xl text-gray-900 group-hover:text-indigo-600 transition-colors duration-300">{a.title}</h2>
          <p class="text-gray-500 mt-3 leading-relaxed">{a.description}</p>
          <p class="text-indigo-600 text-sm font-semibold mt-4">Read the verdict →</p>
        </a>
      ))
    }
  </div>

  <div class="max-w-3xl mx-auto mt-10 p-6 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100">
    <h2 class="font-semibold text-gray-900 mb-2">Coming next in this section</h2>
    <p class="text-gray-500 text-sm leading-relaxed">
      What speed 4K streaming and working from home really need · upload speeds explained. Every guide ships with the same standard: cited benchmarks, honest break-points, and a tool to test your own situation. Meanwhile, the <a href="/tools/" class="text-indigo-600 hover:underline font-medium">calculators</a> and <a href="/converters/" class="text-indigo-600 hover:underline font-medium">converters</a> cover the numbers side.
    </p>
  </div>
</Layout>
