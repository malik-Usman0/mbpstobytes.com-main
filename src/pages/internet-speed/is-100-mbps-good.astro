  <!-- Stress test logic -->
  <script is:inline>
    const stCounters = ['st-4k','st-hd','st-call','st-game'].map((id) => document.getElementById(id));
    const $stDl = document.getElementById("st-dl");
    const $stBar = document.getElementById("st-bar");
    const $stLabel = document.getElementById("st-label");
    const $stVerdict = document.getElementById("st-verdict");
    const BACKGROUND = 5; // smart devices / OS chatter allowance

    const stRender = () => {
      let used = BACKGROUND;
      stCounters.forEach((c) => { used += Number(c.textContent) * Number(c.dataset.mbps); });
      const dl = $stDl.checked;
      const pct = Math.min(100, (used / 100) * 100);
      $stBar.style.width = (dl ? 100 : pct) + "%";
      $stLabel.textContent = dl ? "download consuming all spare bandwidth" : Math.round(used) + " of 100 Mbps used";

      let cls, txt;
      if (dl && used > 60) {
        cls = "text-sm font-semibold text-red-500 mt-3";
        txt = "✗ Congested — the download will starve streams and calls. This evening wants 300 Mbps.";
        $stBar.className = "h-full rounded-full bg-gradient-to-r from-red-400 to-red-500 transition-all duration-500";
      } else if (dl) {
        cls = "text-sm font-semibold text-amber-600 mt-3";
        txt = "⚠ Workable — the download soaks up spare capacity but active streams keep priority. Expect the download to slow, not your shows.";
        $stBar.className = "h-full rounded-full bg-gradient-to-r from-amber-400 to-amber-500 transition-all duration-500";
      } else if (used <= 60) {
        cls = "text-sm font-semibold text-teal-600 mt-3";
        txt = "✓ Comfortable — plenty of headroom for bursts.";
        $stBar.className = "h-full rounded-full bg-gradient-to-r from-teal-400 to-teal-500 transition-all duration-500";
      } else if (used <= 85) {
        cls = "text-sm font-semibold text-amber-600 mt-3";
        txt = "⚠ Busy but fine — one more 4K stream or a download would pinch.";
        $stBar.className = "h-full rounded-full bg-gradient-to-r from-amber-400 to-amber-500 transition-all duration-500";
      } else {
        cls = "text-sm font-semibold text-red-500 mt-3";
        txt = "✗ Over capacity — buffering territory. Your household has outgrown 100 Mbps.";
        $stBar.className = "h-full rounded-full bg-gradient-to-r from-red-400 to-red-500 transition-all duration-500";
      }
      $stVerdict.className = cls;
      $stVerdict.textContent = txt;
    };

    document.querySelectorAll(".st-btn").forEach((b) => {
      b.addEventListener("click", (e) => {
        e.preventDefault();
        const c = document.getElementById(b.dataset.t);
        c.textContent = String(Math.min(6, Math.max(0, Number(c.textContent) + Number(b.dataset.d))));
        stRender();
      });
    });
    $stDl.addEventListener("change", stRender);
    stRender();
  </script>
