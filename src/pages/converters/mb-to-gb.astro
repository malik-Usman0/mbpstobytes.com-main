    ]}
  />

  <!-- Calculator Logic -->
  <script is:inline>
    const el = (id) => document.getElementById(id);
    const $mb = el("mb");
    const $gb = el("gb");
    const $stdSi = el("std-si");
    const $stdIec = el("std-iec");
    const $stdHint = el("std-hint");
    const $mbLabel = el("mb-label");
    const $gbLabel = el("gb-label");
    const $mbBadge = el("mb-badge");
    const $gbBadge = el("gb-badge");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $outGb = el("out-gb");
    const $outGib = el("out-gib");
    const $outKb = el("out-kb");
    const $outBytes = el("out-bytes");
    const $outDl = el("out-dl");

    let state = { lastEdited: "mb", standard: "si", decimals: 3 };

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const fmt = (n) => (Number.isFinite(n) ? Number(n.toFixed(state.decimals)).toLocaleString() : "—");
    const factor = () => (state.standard === "iec" ? 1024 : 1000);
    const mbUnit = () => (state.standard === "iec" ? "MiB" : "MB");
    const gbUnit = () => (state.standard === "iec" ? "GiB" : "GB");

    const fmtTime = (sec) => {
      if (!Number.isFinite(sec)) return "—";
      if (sec >= 3600) { const h = Math.floor(sec/3600); const m = Math.round((sec%3600)/60); return `≈ ${h}h ${m}m`; }
      if (sec >= 60) { const m = Math.floor(sec/60); const s = Math.round(sec%60); return `≈ ${m}m ${s}s`; }
      return `≈ ${Math.round(sec)}s`;
    };

    const refreshUI = () => {
      const si = state.standard === "si";
      const on = "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200";
      const off = "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdSi.className = si ? on : off;
      $stdIec.className = !si ? on : off;
      $stdSi.setAttribute("aria-pressed", String(si));
      $stdIec.setAttribute("aria-pressed", String(!si));
      $stdHint.textContent = si ? "1 GB = 1,000 MB — drives, phones, data plans" : "1 GiB = 1,024 MiB — RAM, Windows file listings";
      $mbLabel.textContent = mbUnit(); $mbBadge.textContent = mbUnit();
      $gbLabel.textContent = gbUnit(); $gbBadge.textContent = gbUnit();
    };

    const render = () => {
      let mbVal;
      if (state.lastEdited === "mb") {
        const m = num($mb.value);
        mbVal = Number.isFinite(m) && $mb.value !== "" ? m : NaN;
        $gb.value = Number.isFinite(mbVal) ? Number((mbVal / factor()).toFixed(Math.max(state.decimals, 6))).toString() : "";
      } else {
        const g = num($gb.value);
        mbVal = Number.isFinite(g) && $gb.value !== "" ? g * factor() : NaN;
        $mb.value = Number.isFinite(mbVal) ? Number(mbVal.toFixed(Math.max(state.decimals, 6))).toString() : "";
      }

      if (!Number.isFinite(mbVal)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$outGb, $outGib, $outKb, $outBytes, $outDl].forEach((o) => (o.textContent = "—"));
        $decValue.textContent = state.decimals;
        return;
      }

      // Interpret the MB value in the chosen standard to get raw bytes
      const bytes = state.standard === "iec" ? mbVal * 1048576 : mbVal * 1000000;
      const gbDec = bytes / 1e9;
      const gib = bytes / 1073741824;
      const kb = bytes / 1000;
      const dlSec = (bytes * 8) / 100000000; // at 100 Mbps

      const primary = state.lastEdited === "mb" ? fmt(mbVal / factor()) + " " + gbUnit() : fmt(mbVal) + " " + mbUnit();
      $resMain.textContent = primary;
      $resSecondary.textContent = fmt(mbVal) + " " + mbUnit() + " = " + fmt(mbVal / factor()) + " " + gbUnit() + (state.standard === "si" ? " (decimal)" : " (binary)");
      $outGb.textContent = fmt(gbDec);
      $outGib.textContent = fmt(gib);
      $outKb.textContent = fmt(kb);
      $outBytes.textContent = Math.round(bytes).toLocaleString();
      $outDl.textContent = fmtTime(dlSec);
      $decValue.textContent = state.decimals;
    };

    $mb.addEventListener("input", () => { state.lastEdited = "mb"; render(); });
    $gb.addEventListener("input", () => { state.lastEdited = "gb"; render(); });
    $stdSi.addEventListener("click", () => { state.standard = "si"; refreshUI(); render(); });
    $stdIec.addEventListener("click", () => { state.standard = "iec"; refreshUI(); render(); });

    document.querySelectorAll(".preset-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        $mb.value = chip.dataset.mb;
        state.lastEdited = "mb";
        render();
      });
    });

    $decMinus.addEventListener("click", () => { state.decimals = Math.max(0, state.decimals - 1); render(); });
    $decPlus.addEventListener("click", () => { state.decimals = Math.min(10, state.decimals + 1); render(); });

    $btnShare.addEventListener("click", async () => {
      if ($resMain.textContent === "—") return;
      const txt = `MB↔GB: ${$mb.value} ${mbUnit()} = ${$gb.value} ${gbUnit()} (${state.standard === "si" ? "decimal" : "binary"}). via mbpstobytes.com/converters/mb-to-gb/`;
      try { await navigator.clipboard.writeText(txt); } catch (e) {}
    });

    $btnReload.addEventListener("click", () => window.location.reload());
    $btnClear.addEventListener("click", () => {
      $mb.value = "";
      $gb.value = "";
      state.lastEdited = "mb";
      render();
    });

    refreshUI();
    render();
  </script>
</Layout>
