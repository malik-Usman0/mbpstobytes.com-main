---
import Layout from '@theme/layouts/Layout.astro';
import RelatedTools from '@theme/components/RelatedTools.astro';

const title = 'Gbps to Mbps Converter – 1 Gbps = 1,000 Mbps, Exactly';
const description =
  'Convert Gbps to Mbps instantly: 1 Gbps = 1,000 Mbps, never 1,024. With MB/s equivalents, multi-gig plan context, and why gigabit tests at ~940 Mbps.';

const siteURL = 'https://www.mbpstobytes.com';
const pageURL = `${siteURL}/converters/gbps-to-mbps/`;

const faqs = [
  {
    question: 'Is 1 Gbps equal to 1,000 or 1,024 Mbps?',
    answer:
      'Exactly 1,000. Data-rate units always use decimal (SI) prefixes per IEC 80000-13: 1 Gbps = 1,000 Mbps = 1,000,000,000 bits per second. The 1,024 factor belongs to binary storage units (GiB, MiB) and never applies to network speeds — any converter claiming 1 Gbps = 1,024 Mbps is applying the wrong standard.',
  },
  {
    question: 'How many Mbps is 2.5 Gbps?',
    answer:
      '2.5 Gbps = 2,500 Mbps, which downloads at up to 312.5 MB/s. This is the speed of 2.5G multi-gig Ethernet ports, now common on routers and motherboards, and of many cable/fiber multi-gig plans.',
  },
  {
    question: 'Is 1000 Mbps the same as 1 Gbps?',
    answer:
      'Yes — 1,000 Mbps and 1 Gbps are two ways of writing the identical speed. ISPs use them interchangeably in gigabit plan marketing. In bytes, both equal a maximum of 125 MB/s.',
  },
  {
    question: 'What is 3000 Mbps in Gbps?',
    answer:
      '3,000 Mbps = 3 Gbps (divide by 1,000). In download terms that is up to 375 MB/s — a 75 GB game in roughly 3 minutes 20 seconds under ideal conditions.',
  },
  {
    question: 'Why does my gigabit plan speed test at ~940 Mbps?',
    answer:
      'That is expected, not a fault. Gigabit Ethernet moves 1,000 Mbps of raw signal, but TCP/IP headers and Ethernet framing consume roughly 6% of it, leaving about 940 Mbps of usable throughput — the ceiling virtually every wired gigabit speed test hits. Over Wi-Fi, the number drops further with signal conditions.',
  },
  {
    question: 'How many Mbps is 10 Gbps?',
    answer:
      '10 Gbps = 10,000 Mbps, or up to 1,250 MB/s — faster than most SSDs can sustain writes. 10G is standard in data centers and increasingly available as residential fiber in some markets.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Converters', item: `${siteURL}/converters/` },
    { '@type': 'ListItem', position: 3, name: 'Gbps to Mbps Converter', item: pageURL },
  ],
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${pageURL}#webapplication`,
  name: 'Gbps to Mbps Converter',
  url: pageURL,
  description,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  browserRequirements: 'Requires JavaScript',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', '@id': `${siteURL}#organization` },
  inLanguage: 'en',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

// Common gigabit-era values with anchors
const commonValues = [
  { gbps: '1', mbps: '1,000', mbs: '125', note: 'The classic "gigabit" plan; tests at ~940 Mbps wired', anchor: '1-gbps' },
  { gbps: '1.2', mbps: '1,200', mbs: '150', note: 'Common cable "gig+" tier', anchor: '1-2-gbps' },
  { gbps: '2', mbps: '2,000', mbs: '250', note: 'Entry multi-gig fiber', anchor: '2-gbps' },
  { gbps: '2.5', mbps: '2,500', mbs: '312.5', note: 'Matches 2.5G Ethernet ports on modern routers/PCs', anchor: '2-5-gbps' },
  { gbps: '3', mbps: '3,000', mbs: '375', note: 'Mid multi-gig fiber tier', anchor: '3-gbps' },
  { gbps: '5', mbps: '5,000', mbs: '625', note: 'Top residential fiber in many markets; 5G Ethernet class', anchor: '5-gbps' },
  { gbps: '8', mbps: '8,000', mbs: '1,000', note: 'The "1 GB per second" milestone — needs 10G gear end-to-end', anchor: '8-gbps' },
  { gbps: '10', mbps: '10,000', mbs: '1,250', note: 'Data-center standard; outruns most consumer SSD writes', anchor: '10-gbps' },
];
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-400">
    <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/converters/" class="hover:text-indigo-600 transition-colors">Converters</a>
    <span class="mx-2">/</span>
    <span class="text-gray-600 font-medium">Gbps to Mbps Converter</span>
  </nav>

  <div class="gap-8 grid grid-cols-1 lg:grid-cols-3">
    <!-- Calculator card -->
    <section class="lg:col-span-2">
      <div class="premium-card">
        <div class="premium-card-inner">
          <div class="flex flex-wrap justify-between items-start gap-6 mb-8">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 rounded-full mb-3">
                <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                <span class="text-indigo-600 text-xs font-semibold uppercase tracking-wide">Live Calculator</span>
              </div>
              <h1 class="font-extrabold text-3xl md:text-4xl text-gray-900 tracking-tight">Gbps to Mbps Converter</h1>
              <p class="text-gray-500 text-base mt-3 max-w-lg leading-relaxed">
                Gigabits to megabits per second, both directions — with the download speed (MB/s) every result really means.
              </p>
            </div>
            <div class="flex items-center gap-2 bg-gray-50 px-4 py-3 rounded-2xl border border-gray-100">
              <span class="text-gray-500 text-sm font-medium">Decimals:</span>
              <button id="dec-minus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">−</button>
              <div id="dec-value" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 text-white font-bold text-sm shadow-lg shadow-indigo-200">2</div>
              <button id="dec-plus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">+</button>
            </div>
          </div>

          <!-- Form -->
          <div class="gap-8 grid md:grid-cols-2">
            <!-- Gbps -->
            <div class="space-y-3">
              <label for="gbps" class="block text-gray-700 text-sm font-semibold">Gigabits per second (Gbps)</label>
              <div class="relative">
                <input id="gbps" inputmode="decimal" placeholder="Enter speed in Gbps" class="glow-input pr-16" value="1" />
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-teal-500 font-bold text-sm">Gbps</div>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">Fiber and multi-gig plans are sold in Gbps: 1, 2, 2.5, 5…</p>
            </div>

            <!-- Mbps -->
            <div class="space-y-3">
              <label for="mbps" class="block text-gray-700 text-sm font-semibold">Megabits per second (Mbps)</label>
              <div class="relative">
                <input id="mbps" inputmode="decimal" placeholder="Enter speed in Mbps" class="glow-input pr-16" value="1000" />
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-amber-500 font-bold text-sm">Mbps</div>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">Speed tests and most plans below 1 Gbps report in Mbps.</p>
            </div>
          </div>

          <!-- Preset chips -->
          <div class="flex flex-wrap items-center gap-2 mt-6" aria-label="Common gigabit speeds">
            <span class="text-gray-400 text-xs font-medium mr-1">Try a plan:</span>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gbps="1">1 Gbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gbps="2">2 Gbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gbps="2.5">2.5 Gbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gbps="5">5 Gbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gbps="10">10 Gbps</button>
          </div>

          <!-- Actions -->
          <div class="gap-4 grid grid-cols-1 sm:grid-cols-3 mt-8">
            <button id="btn-share" class="btn-premium btn-secondary flex justify-center items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              Share result
            </button>
            <button id="btn-reload" class="btn-premium btn-primary">Reload calculator</button>
            <button id="btn-clear" class="btn-premium btn-ghost">Clear all</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <div class="premium-card">
        <div class="premium-card-inner">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg shadow-indigo-200">
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
            <span class="text-gray-900 font-bold text-lg">Result</span>
          </div>
          <div id="result-main" class="result-display mb-3">1,000 Mbps</div>
          <div id="result-secondary" class="text-gray-500 text-sm mb-6">1 Gbps = 1,000 Mbps</div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent my-6"></div>

          <div class="space-y-4">
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">Gbps:</span><span id="out-gbps" class="text-teal-600 font-semibold">1</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">Mbps:</span><span id="out-mbps" class="text-amber-600 font-semibold">1,000</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">Download speed (MB/s):</span><span id="out-mbs" class="text-gray-600 font-semibold">125</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">GB per minute:</span><span id="out-gbmin" class="text-gray-600 font-semibold">7.5</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">Real-world wired (~94%):</span><span id="out-real" class="text-gray-600 font-semibold">≈ 940 Mbps</span></div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <!-- Quick answer -->
  <article class="premium-card mt-12">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">How Many Mbps Is 1 Gbps?</h2>
      <div class="p-6 rounded-2xl bg-gradient-to-r from-indigo-50 via-purple-50 to-pink-50 border-l-4 border-indigo-500 mb-8">
        <p class="text-lg text-gray-700">
          <strong class="text-indigo-600">1 Gbps = exactly 1,000 Mbps</strong> — one billion bits per second. Data-rate units always use decimal prefixes, so the conversion is a clean ×1,000 in either direction: multiply Gbps by 1,000 for Mbps, divide Mbps by 1,000 for Gbps. In download terms, 1 Gbps moves up to <strong class="text-indigo-600">125 MB/s</strong>.
        </p>
        <p class="text-gray-500 text-sm mt-2">Mbps = Gbps × 1,000 &nbsp;·&nbsp; Gbps = Mbps ÷ 1,000 &nbsp;·&nbsp; MB/s = Gbps × 125</p>
      </div>
      <p class="text-gray-600 leading-relaxed">
        A note on a mistake you'll find on some converter sites: there is <strong>no "binary" version of this conversion</strong>. 1 Gbps is never 1,024 Mbps — the 1,024 factor belongs exclusively to binary <em>storage</em> units (GiB, MiB, defined by <a href="https://www.iec.ch/prefixes-binary-multiples" rel="noopener" target="_blank" class="text-indigo-600 hover:underline">IEC 80000-13</a>), while network data rates are decimal by universal convention. Any site offering "1 Gbps = 1,024 Mbps (binary)" is applying the wrong standard — our <a href="/methodology/" class="text-indigo-600 hover:underline font-medium">methodology</a> documents the correct factors.
      </p>
    </div>
  </article>

  <!-- Common values -->
  <section class="premium-card mt-8" id="common-speeds">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-2">Every Gigabit-Era Plan Speed, Converted</h2>
      <p class="text-gray-500 mb-8">The multi-gig tiers ISPs actually sell — in Mbps, in real download speed, and what each one means.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        {
          commonValues.map((v) => (
            <div id={v.anchor} class="p-5 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100 hover:border-indigo-200 transition-colors">
              <h3 class="font-bold text-gray-900 text-lg mb-2">{v.gbps} Gbps = {v.mbps} Mbps</h3>
              <ul class="text-sm text-gray-500 space-y-1">
                <li><span class="text-gray-400">Download speed:</span> <strong class="text-gray-700">{v.mbs} MB/s</strong></li>
                <li class="pt-1">{v.note}</li>
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Conversion tables -->
  <section class="premium-card mt-8">
    <div class="premium-card-inner">
      <div class="flex md:flex-row flex-col md:justify-between md:items-center gap-4 mb-8">
        <h2 class="font-bold text-2xl text-gray-900">Gbps to Mbps Conversion Table</h2>
        <p class="text-gray-400 text-sm font-medium">Formula: <span class="text-gray-600">Mbps = Gbps × 1,000</span></p>
      </div>
      <div class="gap-8 grid md:grid-cols-2">
        <div>
          <h3 class="mb-4 font-semibold text-gray-700">Gbps to Mbps</h3>
          <div class="rounded-2xl border border-gray-100 overflow-x-auto shadow-sm">
            <table class="luxury-table">
              <thead><tr><th>Gbps</th><th>Mbps</th><th>MB/s</th></tr></thead>
              <tbody>
                <tr><td class="text-teal-600 font-semibold">0.5 Gbps</td><td class="text-amber-600">500 Mbps</td><td class="text-gray-500">62.5 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">1 Gbps</td><td class="text-amber-600 font-bold">1,000 Mbps</td><td class="text-gray-500">125 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">1.5 Gbps</td><td class="text-amber-600">1,500 Mbps</td><td class="text-gray-500">187.5 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">2 Gbps</td><td class="text-amber-600">2,000 Mbps</td><td class="text-gray-500">250 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">2.5 Gbps</td><td class="text-amber-600 font-bold">2,500 Mbps</td><td class="text-gray-500">312.5 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">5 Gbps</td><td class="text-amber-600">5,000 Mbps</td><td class="text-gray-500">625 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">10 Gbps</td><td class="text-amber-600 font-bold">10,000 Mbps</td><td class="text-gray-500">1,250 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">40 Gbps</td><td class="text-amber-600">40,000 Mbps</td><td class="text-gray-500">5,000 MB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">100 Gbps</td><td class="text-amber-600">100,000 Mbps</td><td class="text-gray-500">12,500 MB/s</td></tr>
              </tbody>
            </table>
          </div>
        </div>
        <div>
          <h3 class="mb-4 font-semibold text-gray-700">Mbps to Gbps</h3>
          <div class="rounded-2xl border border-gray-100 overflow-x-auto shadow-sm">
            <table class="luxury-table">
              <thead><tr><th>Mbps</th><th>Gbps</th><th>Typical context</th></tr></thead>
              <tbody>
                <tr><td class="text-amber-600 font-semibold">100 Mbps</td><td class="text-teal-600">0.1 Gbps</td><td class="text-gray-500">Standard broadband</td></tr>
                <tr><td class="text-amber-600 font-semibold">500 Mbps</td><td class="text-teal-600">0.5 Gbps</td><td class="text-gray-500">Fast cable/fiber</td></tr>
                <tr><td class="text-amber-600 font-semibold">940 Mbps</td><td class="text-teal-600">0.94 Gbps</td><td class="text-gray-500">Real gigabit wired throughput</td></tr>
                <tr><td class="text-amber-600 font-semibold">1,000 Mbps</td><td class="text-teal-600 font-bold">1 Gbps</td><td class="text-gray-500">"Gigabit" plan</td></tr>
                <tr><td class="text-amber-600 font-semibold">1,200 Mbps</td><td class="text-teal-600">1.2 Gbps</td><td class="text-gray-500">Cable gig+ tier</td></tr>
                <tr><td class="text-amber-600 font-semibold">2,000 Mbps</td><td class="text-teal-600">2 Gbps</td><td class="text-gray-500">Entry multi-gig</td></tr>
                <tr><td class="text-amber-600 font-semibold">3,000 Mbps</td><td class="text-teal-600 font-bold">3 Gbps</td><td class="text-gray-500">Mid multi-gig fiber</td></tr>
                <tr><td class="text-amber-600 font-semibold">5,000 Mbps</td><td class="text-teal-600">5 Gbps</td><td class="text-gray-500">Top residential fiber</td></tr>
                <tr><td class="text-amber-600 font-semibold">10,000 Mbps</td><td class="text-teal-600">10 Gbps</td><td class="text-gray-500">Data-center / 10G fiber</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why gigabit tests at 940 -->
  <article class="premium-card mt-8">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">Why "Gigabit" Really Means ~940 Mbps</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Run a wired speed test on any honest gigabit connection and you'll see a number close to <strong>940 Mbps</strong> — not 1,000. Nothing is broken. Gigabit Ethernet signals at exactly 1,000 Mbps, but every packet you send is wrapped in Ethernet framing and TCP/IP headers, and those wrappers consume bandwidth. The overhead works out to roughly 6% for typical full-size packets, leaving ~940 Mbps of usable data — the ceiling that wired speed tests worldwide bump into.
      </p>
      <div class="p-6 rounded-2xl bg-gradient-to-br from-teal-50 via-white to-amber-50 border-2 border-gray-100 mb-6" role="img" aria-label="Bar showing 1000 Mbps raw signal reduced to about 940 Mbps usable after protocol overhead">
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="font-semibold text-teal-700">Raw line rate: 1,000 Mbps</span><span class="text-gray-400 text-xs">what the wire signals</span></div>
            <div class="h-6 rounded-full bg-gradient-to-r from-teal-400 to-teal-500 shadow-sm" style="width: 100%"></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="font-semibold text-amber-700">Usable throughput: ≈ 940 Mbps</span><span class="text-gray-400 text-xs">after framing + TCP/IP headers</span></div>
            <div class="h-6 rounded-full bg-gradient-to-r from-amber-400 to-amber-500 shadow-sm" style="width: 94%"></div>
          </div>
        </div>
        <p class="text-gray-400 text-xs mt-4 text-center">~6% of every gigabit is spent addressing and delivering the packets themselves. The same per-packet cost is why hardware limits are measured in packet rates — see our <a href="/tools/packets-per-second-calculator/" class="text-indigo-600 hover:underline">PPS calculator</a>.</p>
      </div>
      <p class="text-gray-600 leading-relaxed">
        Getting less than ~900 Mbps on a wired gigabit line usually means a bottleneck elsewhere: a Fast-Ethernet (100 Mbps) switch port in the path, an old Cat5 cable, a router that can't route at line rate, or Wi-Fi in the chain. Multi-gig plans amplify the same problem — a 2.5 Gbps plan needs 2.5G-capable ports on <em>every</em> device between the wall and your PC.
      </p>
    </div>
  </article>

  <!-- Hardware context -->
  <article class="premium-card mt-8">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">Can Your Hardware Actually Carry These Speeds?</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Converting Gbps to Mbps is easy — delivering it is the hard part. Each plan tier assumes a matching link technology, and the weakest link wins:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-gray-100 shadow-sm">
        <table class="luxury-table">
          <caption class="sr-only">Link technologies and the plan speeds they support</caption>
          <thead><tr><th>Link technology</th><th>Line rate</th><th>Realistic wired throughput</th><th>Supports plans up to</th></tr></thead>
          <tbody>
            <tr><td class="text-teal-600 font-semibold">Fast Ethernet (old ports)</td><td class="text-gray-600">100 Mbps</td><td class="text-gray-500">~94 Mbps</td><td class="text-amber-600">100 Mbps — a gigabit killer hiding in old gear</td></tr>
            <tr><td class="text-teal-600 font-semibold">Gigabit Ethernet</td><td class="text-gray-600">1 Gbps</td><td class="text-gray-500">~940 Mbps</td><td class="text-amber-600 font-bold">1 Gbps</td></tr>
            <tr><td class="text-teal-600 font-semibold">2.5G Ethernet</td><td class="text-gray-600">2.5 Gbps</td><td class="text-gray-500">~2.35 Gbps</td><td class="text-amber-600">2–2.5 Gbps multi-gig</td></tr>
            <tr><td class="text-teal-600 font-semibold">5G / 10G Ethernet</td><td class="text-gray-600">5–10 Gbps</td><td class="text-gray-500">~4.7–9.4 Gbps</td><td class="text-amber-600">Every current residential tier</td></tr>
            <tr><td class="text-teal-600 font-semibold">Wi-Fi (any generation)</td><td class="text-gray-600">varies</td><td class="text-gray-500">typically 30–70% of link rate</td><td class="text-amber-600">Test wired before judging a multi-gig plan</td></tr>
          </tbody>
        </table>
      </div>
      <p class="mt-6 text-gray-400 text-sm">Throughput estimates assume full-size packets and the ~6% protocol overhead described above. Wi-Fi ranges vary enormously with distance, interference, and client hardware — always benchmark gigabit-class plans over a cable first.</p>
