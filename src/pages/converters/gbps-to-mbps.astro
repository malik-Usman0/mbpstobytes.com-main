  <!-- Calculator Logic -->
  <script is:inline>
    const el = (id) => document.getElementById(id);
    const $gbps = el("gbps");
    const $mbps = el("mbps");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $outGbps = el("out-gbps");
    const $outMbps = el("out-mbps");
    const $outMbs = el("out-mbs");
    const $outGbMin = el("out-gbmin");
    const $outReal = el("out-real");

    let state = { lastEdited: "gbps", decimals: 2 };

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const fmt = (n) => (Number.isFinite(n) ? Number(n.toFixed(state.decimals)).toLocaleString() : "—");

    const render = () => {
      let gbps;
      if (state.lastEdited === "gbps") {
        const g = num($gbps.value);
        gbps = Number.isFinite(g) && $gbps.value !== "" ? g : NaN;
        $mbps.value = Number.isFinite(gbps) ? Number((gbps * 1000).toFixed(Math.max(state.decimals, 4))).toString() : "";
      } else {
        const m = num($mbps.value);
        gbps = Number.isFinite(m) && $mbps.value !== "" ? m / 1000 : NaN;
        $gbps.value = Number.isFinite(gbps) ? Number(gbps.toFixed(Math.max(state.decimals, 4))).toString() : "";
      }

      if (!Number.isFinite(gbps)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$outGbps, $outMbps, $outMbs, $outGbMin, $outReal].forEach((o) => (o.textContent = "—"));
        $decValue.textContent = state.decimals;
        return;
      }

      const mbps = gbps * 1000;
      const mbs = mbps / 8;
      const gbMin = (mbs * 60) / 1000;

      $resMain.textContent = state.lastEdited === "gbps" ? fmt(mbps) + " Mbps" : fmt(gbps) + " Gbps";
      $resSecondary.textContent = fmt(gbps) + " Gbps = " + fmt(mbps) + " Mbps";
      $outGbps.textContent = fmt(gbps);
      $outMbps.textContent = fmt(mbps);
      $outMbs.textContent = fmt(mbs);
      $outGbMin.textContent = fmt(gbMin);
      $outReal.textContent = "≈ " + fmt(mbps * 0.94) + " Mbps";
      $decValue.textContent = state.decimals;
    };

    $gbps.addEventListener("input", () => { state.lastEdited = "gbps"; render(); });
    $mbps.addEventListener("input", () => { state.lastEdited = "mbps"; render(); });

    document.querySelectorAll(".preset-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        $gbps.value = chip.dataset.gbps;
        state.lastEdited = "gbps";
        render();
      });
    });

    $decMinus.addEventListener("click", () => { state.decimals = Math.max(0, state.decimals - 1); render(); });
    $decPlus.addEventListener("click", () => { state.decimals = Math.min(10, state.decimals + 1); render(); });

    $btnShare.addEventListener("click", async () => {
      if ($resMain.textContent === "—") return;
      const txt = `Gbps↔Mbps: ${$gbps.value} Gbps = ${$mbps.value} Mbps (≈ ${$outMbs.textContent} MB/s). via mbpstobytes.com/converters/gbps-to-mbps/`;
      try { await navigator.clipboard.writeText(txt); } catch (e) {}
    });

    $btnReload.addEventListener("click", () => window.location.reload());
    $btnClear.addEventListener("click", () => {
      $gbps.value = "";
      $mbps.value = "";
      state.lastEdited = "gbps";
      render();
    });

    render();
  </script>
</Layout>
