---
import Layout from '@theme/layouts/Layout.astro';
import RelatedTools from '@theme/components/RelatedTools.astro';

const title = 'GB to GiB Converter – See What Windows Will Really Show';
const description =
  'Convert GB to GiB both ways: 1 GB = 0.9313 GiB, 1 GiB = 1.0737 GB. Instant results for any drive or file size, with the exact ×10⁹ ÷ 2³⁰ math shown.';

const siteURL = 'https://www.mbpstobytes.com';
const pageURL = `${siteURL}/converters/gb-to-gib/`;

const faqs = [
  {
    question: 'How many GiB are in a GB?',
    answer:
      '1 GB = 0.93132 GiB. A gigabyte is 1,000,000,000 bytes while a gibibyte is 1,073,741,824 bytes (1,024³), so dividing the two gives 0.9313. Practical anchors: 100 GB = 93.13 GiB, 500 GB = 465.66 GiB, and 1,000 GB = 931.32 GiB — the famous "1 TB drive shows 931 GB" number.',
  },
  {
    question: 'What is the GB to GiB formula?',
    answer:
      'GiB = GB × 10⁹ ÷ 2³⁰, which simplifies to GiB = GB × 0.93132257. In reverse, GB = GiB × 1.07374182. Worked example: 250 GB × 0.93132 = 232.83 GiB. Every result on this page uses exactly this arithmetic — no rounding shortcuts until the final displayed decimals.',
  },
  {
    question: 'Is GiB bigger than GB?',
    answer:
      'Yes, by about 7.4%: one gibibyte holds 1,073,741,824 bytes against the gigabyte\'s even 1,000,000,000. Because the unit is bigger, the same data makes a smaller number in GiB — which is why capacities "shrink" when Windows reports them in binary units.',
  },
  {
    question: 'Why does Windows show fewer GB than the drive box says?',
    answer:
      'Windows computes storage by dividing bytes by 1,024³ — producing gibibytes — but prints the result with a "GB" label. A 1 TB drive (1,000,000,000,000 bytes, all present) becomes 1,000,000,000,000 ÷ 1,073,741,824 = 931.32, displayed as "931 GB." It is a unit conversion, not missing space. Our GB vs GiB guide walks through the whole story.',
  },
  {
    question: 'Is 1 GiB equal to 1,024 MB?',
    answer:
      'Not quite — mixed units make it messy. 1 GiB = 1,024 MiB exactly (binary throughout), and 1 GiB = 1,073.74 MB (converting to decimal megabytes). The clean statements are: 1 GiB = 1,024 MiB = 1,073,741,824 bytes, and 1 GB = 1,000 MB = 1,000,000,000 bytes. Pick one system and stay in it.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Converters', item: `${siteURL}/converters/` },
    { '@type': 'ListItem', position: 3, name: 'GB to GiB Converter', item: pageURL },
  ],
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${pageURL}#webapplication`,
  name: 'GB to GiB Converter',
  url: pageURL,
  description,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  browserRequirements: 'Requires JavaScript',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', '@id': `${siteURL}#organization` },
  inLanguage: 'en',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

// High-intent values: phone/SSD sizes + the RAM special case
const commonValues = [
  { gb: '1', gib: '0.931', note: 'The base ratio itself', anchor: '1-gb' },
  { gb: '100', gib: '93.132', note: 'Cloud plan / partition math', anchor: '100-gb' },
  { gb: '256', gib: '238.419', note: 'Phone & base-model SSD class', anchor: '256-gb' },
  { gb: '500', gib: '465.661', note: 'Windows shows ~465.66 "GB"', anchor: '500-gb' },
  { gb: '1,000', gib: '931.323', note: 'The classic 1 TB drive readout', anchor: '1000-gb' },
  { gb: '2,000', gib: '1,862.645', note: '2 TB — Windows flips to "1.81 TB"', anchor: '2000-gb' },
];
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-400">
    <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/converters/" class="hover:text-indigo-600 transition-colors">Converters</a>
    <span class="mx-2">/</span>
    <span class="text-gray-600 font-medium">GB to GiB Converter</span>
  </nav>

  <div class="gap-8 grid grid-cols-1 lg:grid-cols-3">
    <!-- Calculator -->
    <section class="lg:col-span-2">
      <div class="premium-card">
        <div class="premium-card-inner">
          <div class="flex flex-wrap justify-between items-start gap-6 mb-8">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 rounded-full mb-3">
                <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                <span class="text-indigo-600 text-xs font-semibold uppercase tracking-wide">Live Calculator</span>
              </div>
              <h1 class="font-extrabold text-3xl md:text-4xl text-gray-900 tracking-tight">GB to GiB Converter</h1>
              <p class="text-gray-500 text-base mt-3 max-w-lg leading-relaxed">
                Gigabytes (decimal) to gibibytes (binary), both directions — the conversion behind every "why does my drive look smaller?" moment.
              </p>
            </div>
            <div class="flex items-center gap-2 bg-gray-50 px-4 py-3 rounded-2xl border border-gray-100">
              <span class="text-gray-500 text-sm font-medium">Decimals:</span>
              <button id="dec-minus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">−</button>
              <div id="dec-value" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 text-white font-bold text-sm shadow-lg shadow-indigo-200">3</div>
              <button id="dec-plus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">+</button>
            </div>
          </div>

          <!-- Form -->
          <div class="gap-8 grid md:grid-cols-2">
            <div class="space-y-3">
              <label for="gb" class="block text-gray-700 text-sm font-semibold">Gigabytes (GB) — decimal</label>
              <div class="relative">
                <input id="gb" inputmode="decimal" placeholder="Enter gigabytes" class="glow-input pr-14" value="1000" />
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-teal-500 font-bold text-sm">GB</div>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">What drive boxes, spec sheets, and cloud plans mean: 10⁹ bytes.</p>
            </div>
            <div class="space-y-3">
              <label for="gib" class="block text-gray-700 text-sm font-semibold">Gibibytes (GiB) — binary</label>
              <div class="relative">
                <input id="gib" inputmode="decimal" placeholder="Enter gibibytes" class="glow-input pr-14" value="931.323" />
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-amber-500 font-bold text-sm">GiB</div>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">What Windows, Steam, and RAM actually count: 2³⁰ bytes.</p>
            </div>
          </div>

          <!-- Windows readout -->
          <div class="mt-6 p-5 rounded-2xl bg-gradient-to-r from-indigo-50 to-white border border-indigo-100 flex flex-wrap items-center justify-between gap-3">
            <span class="text-gray-600 text-sm font-medium">🪟 Windows will display this capacity as:</span>
            <span id="win-shows" class="text-indigo-600 font-extrabold text-lg">931.32 "GB"</span>
          </div>

          <!-- Preset chips -->
          <div class="flex flex-wrap items-center gap-2 mt-6" aria-label="Common sizes">
            <span class="text-gray-400 text-xs font-medium mr-1">Try a size:</span>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gb="256">256 GB</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gb="500">500 GB</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gb="1000">1 TB</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gb="2000">2 TB</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-gb="4000">4 TB</button>
          </div>

          <p class="text-gray-400 text-xs mt-6">Formula: GiB = GB × 10⁹ ÷ 2³⁰ = GB × 0.93132257 · reverse: GB = GiB × 1.07374182. Both fields are editable — type in either one.</p>
        </div>
      </div>

      <!-- Formula walkthrough -->
      <article class="premium-card mt-8">
        <div class="premium-card-inner">
          <h2 class="font-bold text-2xl text-gray-900 mb-6">The Formula, Worked Once by Hand</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Both units count bytes; they disagree only on what "giga" multiplies. GB uses the metric ladder (×1,000 per step), GiB uses the binary ladder (×1,024 per step). Converting is one multiplication:
          </p>
          <div class="p-6 rounded-2xl bg-gradient-to-br from-teal-50 via-white to-indigo-50 border-2 border-gray-100 mb-6 text-center">
            <p class="text-gray-700 font-mono text-sm md:text-base">500 GB × 1,000,000,000 = 500,000,000,000 bytes</p>
            <p class="text-gray-400 text-xs my-2">then divide by 1,073,741,824 (= 1,024³)</p>
            <p class="text-indigo-600 font-mono font-bold text-sm md:text-base">500,000,000,000 ÷ 1,073,741,824 = 465.661 GiB</p>
          </div>
          <p class="text-gray-600 leading-relaxed">
            That 465.66 is exactly what Windows prints (labeled "GB") for a 500 GB drive — the conversion and the "shrink" are the same arithmetic. The full story of why two systems exist, who uses which, and how the gap compounds from 2.4% at kilobyte scale to 12.6% at petabyte scale lives in our companion guide: <a href="/learn/gb-vs-gib/" class="text-indigo-600 hover:underline font-medium">GB vs GiB, explained properly</a>.
          </p>
        </div>
      </article>

      <!-- Common values -->
      <article class="premium-card mt-8">
        <div class="premium-card-inner">
          <h2 class="font-bold text-2xl text-gray-900 mb-6">Common GB to GiB Values</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {commonValues.map((v) => (
              <div id={v.anchor} class="p-5 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100 hover:border-indigo-200 transition-colors">
                <p class="font-bold text-gray-900"><span class="text-teal-600">{v.gb} GB</span> = <span class="text-indigo-600">{v.gib} GiB</span></p>
                <p class="text-gray-500 text-sm mt-1">{v.note}</p>
              </div>
            ))}
          </div>
          <p class="text-gray-600 leading-relaxed mt-6">
            Going the other way, the reverse anchors worth memorizing: <strong>1 GiB = 1.074 GB</strong>, 16 GiB (a typical RAM kit's true size) = 17.18 GB, and 1,024 GiB = 1 TiB = 1.0995 TB. For drive-scale numbers — where Windows switches to "TB" labels — the <a href="/converters/gb-to-tb/" class="text-indigo-600 hover:underline font-medium">GB to TB converter</a> shows the Windows readout for every common capacity.
          </p>
        </div>
      </article>

      <!-- FAQs -->
      <section class="mt-12" id="faqs">
        <div class="text-center mb-8">
          <h2 class="font-bold text-2xl text-gray-900">Frequently Asked Questions</h2>
          <p class="text-gray-500 text-sm mt-2">Quick answers on converting GB to GiB</p>
        </div>
        <div class="space-y-4">
          {
            faqs.map((faq) => (
              <details class="group premium-card overflow-hidden">
                <summary class="flex justify-between items-center gap-4 p-6 cursor-pointer list-none font-semibold text-gray-800 select-none hover:text-indigo-600 transition-colors">
                  <span class="group-open:text-indigo-600">{faq.question}</span>
                  <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center group-open:bg-indigo-50 group-open:border-indigo-100 transition-all duration-300">
                    <svg class="w-5 h-5 text-gray-400 group-open:text-indigo-600 transform group-open:rotate-180 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </summary>
                <div class="px-6 pb-6 text-gray-600 leading-relaxed">{faq.answer}</div>
              </details>
            ))
          }
        </div>
      </section>
    </section>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <div class="premium-card">
        <div class="premium-card-inner">
          <h2 class="font-bold text-lg text-gray-900 mb-4">Quick Reference</h2>
          <div class="overflow-x-auto">
            <table class="luxury-table text-sm">
              <caption class="sr-only">Quick GB to GiB reference table</caption>
              <thead><tr><th>GB</th><th>GiB</th></tr></thead>
              <tbody>
                <tr><td class="text-teal-600 font-semibold">1</td><td class="text-gray-600">0.931</td></tr>
                <tr><td class="text-teal-600 font-semibold">10</td><td class="text-gray-600">9.313</td></tr>
                <tr><td class="text-teal-600 font-semibold">50</td><td class="text-gray-600">46.566</td></tr>
                <tr><td class="text-teal-600 font-semibold">100</td><td class="text-gray-600">93.132</td></tr>
                <tr><td class="text-teal-600 font-semibold">250</td><td class="text-gray-600">232.831</td></tr>
                <tr><td class="text-teal-600 font-semibold">500</td><td class="text-gray-600">465.661</td></tr>
                <tr><td class="text-teal-600 font-semibold">1,000</td><td class="text-gray-600">931.323</td></tr>
                <tr><td class="text-teal-600 font-semibold">2,000</td><td class="text-gray-600">1,862.645</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-gray-400 text-xs mt-4">GiB → GB: multiply by 1.0737. All values exact to shown decimals.</p>
        </div>
      </div>

      <div class="premium-card">
        <div class="premium-card-inner">
          <h2 class="font-bold text-lg text-gray-900 mb-3">The One-Line Rule</h2>
          <p class="text-gray-500 text-sm leading-relaxed">
            <strong class="text-gray-700">Storage you buy is decimal; what Windows shows is binary with a decimal label.</strong> If two capacity numbers disagree by roughly 7%, you're almost certainly looking at the same bytes in two dialects — nothing is missing.
          </p>
        </div>
      </div>
    </aside>
  </div>

  <RelatedTools
    tools={[
      {
        name: 'GB vs GiB Explained',
        url: '/learn/gb-vs-gib/',
        description: 'The full story: history, the OS behavior table, and the drive label decoder.',
        icon: '📖',
      },
      {
        name: 'GB to TB Converter',
        url: '/converters/gb-to-tb/',
        description: 'Drive-scale conversions with the Windows readout for every size.',
        icon: '🗄️',
      },
      {
        name: 'MB to GB Converter',
        url: '/converters/mb-to-gb/',
        description: 'One rung down the ladder — decimal and binary side by side.',
        icon: '💾',
      },
    ]}
  />

  <!-- Converter logic -->
  <script is:inline>
    const RATIO = 1e9 / 1073741824; // GB → GiB
    const $gb = document.getElementById("gb");
    const $gib = document.getElementById("gib");
    const $win = document.getElementById("win-shows");
    const $decValue = document.getElementById("dec-value");
    let decimals = 3;

    const fmt = (n) => n.toLocaleString("en-US", { minimumFractionDigits: 0, maximumFractionDigits: decimals });
    const trunc2 = (x) => Math.floor(x * 100) / 100;

    const updateWin = (gbVal) => {
      if (!isFinite(gbVal) || gbVal <= 0) { $win.textContent = "—"; return; }
      const bytes = gbVal * 1e9;
      const gib = bytes / 1073741824;
      $win.textContent = gib >= 1024 ? trunc2(bytes / 1099511627776).toLocaleString("en-US") + ' "TB"' : trunc2(gib).toLocaleString("en-US") + ' "GB"';
    };

    const fromGb = () => {
      const v = parseFloat($gb.value.replace(/,/g, ""));
      if (!isFinite(v)) { $gib.value = ""; updateWin(NaN); return; }
      $gib.value = fmt(v * RATIO);
      updateWin(v);
    };
    const fromGib = () => {
      const v = parseFloat($gib.value.replace(/,/g, ""));
      if (!isFinite(v)) { $gb.value = ""; updateWin(NaN); return; }
      const gbVal = v / RATIO;
      $gb.value = fmt(gbVal);
      updateWin(gbVal);
    };

    $gb.addEventListener("input", fromGb);
    $gib.addEventListener("input", fromGib);

    document.querySelectorAll(".preset-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        $gb.value = chip.dataset.gb;
        fromGb();
      });
    });

    document.getElementById("dec-minus").addEventListener("click", () => {
      decimals = Math.max(0, decimals - 1); $decValue.textContent = decimals; fromGb();
    });
    document.getElementById("dec-plus").addEventListener("click", () => {
      decimals = Math.min(6, decimals + 1); $decValue.textContent = decimals; fromGb();
    });
  </script>
</Layout>
