  <RelatedTools
    tools={[
      {
        name: 'Mbps to Bytes Converter',
        url: '/',
        description: 'The reverse conversion — turn your internet plan speed (Mbps) into Bytes/s, KB/s and MB/s.',
        icon: '⇄',
      },
      {
        name: 'Mbps to MB/s Converter',
        url: '/converters/mbps-to-mbs/',
        description: 'See what your internet plan delivers in real download speed — with plan presets and MiB/s support.',
        icon: '🚀',
      },
      {
        name: 'All Converters & Tools',
        url: '/converters/',
        description: 'Browse every data-rate converter and calculator on the site, organized by category.',
        icon: '🧰',
      },
    ]}
  />

  <!-- Calculator Logic -->
  <script is:inline>
    const BITS_PER_MEGABIT = 1_000_000;
    const BITS_PER_BYTE = 8;

    const el = (id) => document.getElementById(id);
    const $mbps = el("mbps");
    const $bytes = el("bytes");
    const $byteUnit = el("byte-unit");
    const $stdSi = el("std-si");
    const $stdIec = el("std-iec");
    const $stdHint = el("std-hint");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $outMbps = el("out-mbps");
    const $outBits = el("out-bits");
    const $outBps = el("out-bps");
    const $outKBps = el("out-kbps");
    const $outMBps = el("out-mBps");
    const $lblKb = el("lbl-kb");
    const $lblMb = el("lbl-mb");

    let state = { mbps: "", bytes: "", byteUnit: "B", standard: "si", decimals: 2, lastEdited: "bytes", dirty: false };

    const UNIT_POWERS = { B: 0, KB: 1, MB: 2, GB: 3 };
    const SI_LABELS = { B: "B/s", KB: "KB/s", MB: "MB/s", GB: "GB/s" };
    const IEC_LABELS = { B: "B/s", KB: "KiB/s", MB: "MiB/s", GB: "GiB/s" };

    const unitBase = () => (state.standard === "iec" ? 1024 : 1000);
    const unitFactor = () => Math.pow(unitBase(), UNIT_POWERS[state.byteUnit]);
    const unitLabel = () => (state.standard === "iec" ? IEC_LABELS : SI_LABELS)[state.byteUnit];

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const format = (n) => {
      if (!Number.isFinite(n)) return "—";
      return Number(n.toFixed(state.decimals)).toLocaleString();
    };

    const setDirty = (v = true) => {
      state.dirty = v;
      $btnClear.disabled = !v;
      $btnClear.className = v ? "btn-premium btn-danger flex justify-center items-center" : "btn-premium btn-ghost opacity-50 cursor-not-allowed";
    };

    const currentRawBps = () => {
      if (state.lastEdited === "mbps") {
        const m = num(state.mbps);
        return Number.isFinite(m) && state.mbps !== "" ? (m * BITS_PER_MEGABIT) / BITS_PER_BYTE : NaN;
      }
      const b = num(state.bytes);
      return Number.isFinite(b) && state.bytes !== "" ? b * unitFactor() : NaN;
    };

    const updateSidebar = () => {
      const rawBps = currentRawBps();
      const si = state.standard === "si";
      $lblKb.textContent = si ? "KB/s:" : "KiB/s:";
      $lblMb.textContent = si ? "MB/s:" : "MiB/s:";

      if (!Number.isFinite(rawBps)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$outMbps, $outBits, $outBps, $outKBps, $outMBps].forEach((o) => (o.textContent = "—"));
        return;
      }

      const bits = rawBps * BITS_PER_BYTE;
      const mbps = bits / BITS_PER_MEGABIT;
      const base = unitBase();
      const uVal = rawBps / unitFactor();
      const uLbl = unitLabel();

      $resMain.textContent = state.lastEdited === "bytes" ? format(mbps) + " Mbps" : format(uVal) + " " + uLbl;
      $resSecondary.textContent = state.lastEdited === "bytes" ? format(uVal) + " " + uLbl + " = " + format(mbps) + " Mbps" : format(mbps) + " Mbps = " + format(uVal) + " " + uLbl;

      $outMbps.textContent = format(mbps);
      $outBits.textContent = format(bits);
      $outBps.textContent = format(rawBps);
      $outKBps.textContent = format(rawBps / base);
      $outMBps.textContent = format(rawBps / (base * base));
    };

    const updateNumbers = () => {
      if (state.lastEdited === "bytes") {
        const b = num(state.bytes);
        if (!Number.isFinite(b) || state.bytes === "") {
          state.mbps = "";
          $mbps.value = "";
        } else {
          const mbps = (b * unitFactor() * BITS_PER_BYTE) / BITS_PER_MEGABIT;
          const mFmt = Number(mbps.toFixed(Math.max(state.decimals, 6))).toString();
          state.mbps = mFmt;
          $mbps.value = mFmt;
        }
      } else {
        const m = num(state.mbps);
        if (!Number.isFinite(m) || state.mbps === "") {
          state.bytes = "";
          $bytes.value = "";
        } else {
          const uVal = (m * BITS_PER_MEGABIT) / BITS_PER_BYTE / unitFactor();
          const bFmt = Number(uVal.toFixed(Math.max(state.decimals, 6))).toString();
          state.bytes = bFmt;
          $bytes.value = bFmt;
        }
      }
      updateSidebar();
      $decValue.textContent = state.decimals;
    };

    const refreshStandardUI = () => {
      const si = state.standard === "si";
      $stdSi.className = si ? "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200" : "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdIec.className = !si ? "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200" : "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdSi.setAttribute("aria-pressed", String(si));
      $stdIec.setAttribute("aria-pressed", String(!si));
      $stdHint.textContent = si ? "1 KB = 1,000 B · 1 MB = 1,000,000 B" : "1 KiB = 1,024 B · 1 MiB = 1,048,576 B";
      const labels = si ? SI_LABELS : IEC_LABELS;
      [...$byteUnit.options].forEach((opt) => (opt.textContent = labels[opt.value]));
    };

    const setStandard = (std) => {
      state.standard = std;
      refreshStandardUI();
      updateNumbers();
    };

    $bytes.addEventListener("input", () => {
      state.bytes = $bytes.value;
      state.lastEdited = "bytes";
      setDirty(true);
      updateNumbers();
    });

    $mbps.addEventListener("input", () => {
      state.mbps = $mbps.value;
      state.lastEdited = "mbps";
      setDirty(true);
      updateNumbers();
    });

    $byteUnit.addEventListener("change", () => {
      state.byteUnit = $byteUnit.value;
      updateNumbers();
    });

    $stdSi.addEventListener("click", () => setStandard("si"));
    $stdIec.addEventListener("click", () => setStandard("iec"));

    $decMinus.addEventListener("click", () => {
      state.decimals = Math.max(0, state.decimals - 1);
      updateNumbers();
    });
    $decPlus.addEventListener("click", () => {
      state.decimals = Math.min(10, state.decimals + 1);
      updateNumbers();
    });

    $btnShare.addEventListener("click", async () => {
      const rawBps = currentRawBps();
      if (!Number.isFinite(rawBps)) return;
      const mbps = (rawBps * BITS_PER_BYTE) / BITS_PER_MEGABIT;
      const txt = `Bytes↔Mbps: ${format(rawBps)} B/s = ${format(mbps)} Mbps. via mbpstobytes.com/converters/bytes-to-mbps/`;
      try {
        await navigator.clipboard.writeText(txt);
      } catch (e) {}
    });

    $btnReload.addEventListener("click", () => window.location.reload());

    $btnClear.addEventListener("click", () => {
      const std = state.standard;
      const unit = state.byteUnit;
      state = { mbps: "", bytes: "", byteUnit: unit, standard: std, decimals: 2, lastEdited: "bytes", dirty: false };
      $mbps.value = "";
      $bytes.value = "";
      $decValue.textContent = state.decimals;
      updateSidebar();
      setDirty(false);
    });

    (function init() {
      refreshStandardUI();
      updateSidebar();
      setDirty(false);
    })();
  </script>
</Layout>
