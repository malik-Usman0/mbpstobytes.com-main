  <!-- Calculator Logic -->
  <script is:inline>
    const BITS_PER_BYTE = 8;
    const MB_SI = 1_000_000;
    const MIB = 1_048_576;

    const el = (id) => document.getElementById(id);
    const $mbps = el("mbps");
    const $mbs = el("mbs");
    const $stdSi = el("std-si");
    const $stdIec = el("std-iec");
    const $stdHint = el("std-hint");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $outMbps = el("out-mbps");
    const $outMbs = el("out-mbs");
    const $outKbs = el("out-kbs");
    const $outMbMin = el("out-mbmin");
    const $outGbHr = el("out-gbhr");
    const $lblMbs = el("lbl-mbs");
    const $lblKbs = el("lbl-kbs");
    const $unitLabel = el("mbs-unit-label");
    const $unitBadge = el("mbs-unit-badge");

    let state = { mbps: "", mbs: "", standard: "si", decimals: 2, lastEdited: "mbps", dirty: false };

    const byteUnitBytes = () => (state.standard === "iec" ? MIB : MB_SI);
    const unitName = () => (state.standard === "iec" ? "MiB/s" : "MB/s");
    const kUnitName = () => (state.standard === "iec" ? "KiB/s" : "KB/s");
    const kBytes = () => (state.standard === "iec" ? 1024 : 1000);

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const format = (n) => {
      if (!Number.isFinite(n)) return "—";
      return Number(n.toFixed(state.decimals)).toLocaleString();
    };

    const setDirty = (v = true) => {
      state.dirty = v;
      $btnClear.disabled = !v;
      $btnClear.className = v ? "btn-premium btn-danger flex justify-center items-center" : "btn-premium btn-ghost opacity-50 cursor-not-allowed";
    };

    // Raw bits/s from whichever side was edited last
    const currentBps = () => {
      if (state.lastEdited === "mbps") {
        const m = num(state.mbps);
        return Number.isFinite(m) && state.mbps !== "" ? m * 1_000_000 : NaN;
      }
      const b = num(state.mbs);
      return Number.isFinite(b) && state.mbs !== "" ? b * byteUnitBytes() * BITS_PER_BYTE : NaN;
    };

    const updateSidebar = () => {
      $lblMbs.textContent = unitName() + ":";
      $lblKbs.textContent = kUnitName() + ":";

      const bps = currentBps();
      if (!Number.isFinite(bps)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$outMbps, $outMbs, $outKbs, $outMbMin, $outGbHr].forEach((o) => (o.textContent = "—"));
        return;
      }

      const mbps = bps / 1_000_000;
      const bytesPerSec = bps / BITS_PER_BYTE;
      const mbs = bytesPerSec / byteUnitBytes();
      const kbs = bytesPerSec / kBytes();
      const mbPerMin = (bytesPerSec * 60) / MB_SI;
      const gbPerHr = (bytesPerSec * 3600) / 1_000_000_000;

      $resMain.textContent = state.lastEdited === "mbps" ? format(mbs) + " " + unitName() : format(mbps) + " Mbps";
      $resSecondary.textContent = format(mbps) + " Mbps = " + format(mbs) + " " + unitName();

      $outMbps.textContent = format(mbps);
      $outMbs.textContent = format(mbs);
      $outKbs.textContent = format(kbs);
      $outMbMin.textContent = format(mbPerMin) + " MB";
      $outGbHr.textContent = format(gbPerHr) + " GB";
    };

    const updateNumbers = () => {
      if (state.lastEdited === "mbps") {
        const m = num(state.mbps);
        if (!Number.isFinite(m) || state.mbps === "") {
          state.mbs = "";
          $mbs.value = "";
        } else {
          const mbs = (m * 1_000_000) / BITS_PER_BYTE / byteUnitBytes();
          const v = Number(mbs.toFixed(Math.max(state.decimals, 6))).toString();
          state.mbs = v;
          $mbs.value = v;
        }
      } else {
        const b = num(state.mbs);
        if (!Number.isFinite(b) || state.mbs === "") {
          state.mbps = "";
          $mbps.value = "";
        } else {
          const mbps = (b * byteUnitBytes() * BITS_PER_BYTE) / 1_000_000;
          const v = Number(mbps.toFixed(Math.max(state.decimals, 6))).toString();
          state.mbps = v;
          $mbps.value = v;
        }
      }
      updateSidebar();
      $decValue.textContent = state.decimals;
    };

    const refreshStandardUI = () => {
      const si = state.standard === "si";
      $stdSi.className = si ? "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200" : "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdIec.className = !si ? "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200" : "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdSi.setAttribute("aria-pressed", String(si));
      $stdIec.setAttribute("aria-pressed", String(!si));
      $stdHint.textContent = si ? "1 MB = 1,000,000 bytes · MB/s = Mbps ÷ 8" : "1 MiB = 1,048,576 bytes · MiB/s = Mbps ÷ 8.388608";
      $unitLabel.textContent = unitName();
      $unitBadge.textContent = unitName();
    };

    $mbps.addEventListener("input", () => {
      state.mbps = $mbps.value;
      state.lastEdited = "mbps";
      setDirty(true);
      updateNumbers();
    });

    $mbs.addEventListener("input", () => {
      state.mbs = $mbs.value;
      state.lastEdited = "mbs";
      setDirty(true);
      updateNumbers();
    });

    $stdSi.addEventListener("click", () => { state.standard = "si"; refreshStandardUI(); updateNumbers(); });
    $stdIec.addEventListener("click", () => { state.standard = "iec"; refreshStandardUI(); updateNumbers(); });

    document.querySelectorAll(".preset-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        state.mbps = chip.dataset.mbps;
        state.lastEdited = "mbps";
        $mbps.value = state.mbps;
        setDirty(true);
        updateNumbers();
      });
    });

    $decMinus.addEventListener("click", () => { state.decimals = Math.max(0, state.decimals - 1); updateNumbers(); });
    $decPlus.addEventListener("click", () => { state.decimals = Math.min(10, state.decimals + 1); updateNumbers(); });

    $btnShare.addEventListener("click", async () => {
      const bps = currentBps();
      if (!Number.isFinite(bps)) return;
      const mbps = bps / 1_000_000;
      const mbs = bps / BITS_PER_BYTE / byteUnitBytes();
      const txt = `Mbps→MB/s: ${format(mbps)} Mbps = ${format(mbs)} ${unitName()}. via mbpstobytes.com/converters/mbps-to-mbs/`;
      try { await navigator.clipboard.writeText(txt); } catch (e) {}
    });

    $btnReload.addEventListener("click", () => window.location.reload());

    $btnClear.addEventListener("click", () => {
      const std = state.standard;
      state = { mbps: "", mbs: "", standard: std, decimals: 2, lastEdited: "mbps", dirty: false };
      $mbps.value = "";
      $mbs.value = "";
      $decValue.textContent = state.decimals;
      updateSidebar();
      setDirty(false);
    });

    (function init() {
      refreshStandardUI();
      updateSidebar();
      setDirty(false);
    })();
  </script>

  <!-- Plan explorer -->
  <script is:inline>
    const slider = document.getElementById("plan-slider");
    const label = document.getElementById("plan-label");
    const pxMbs = document.getElementById("px-mbs");
    const pxMin = document.getElementById("px-min");
    const pxHr = document.getElementById("px-hr");
    const pxGame = document.getElementById("px-game");

    const fmtSize = (mb) => (mb >= 1000 ? (mb / 1000).toFixed(mb >= 10000 ? 0 : 2).replace(/\.00$/, "") + " GB" : Math.round(mb) + " MB");
    const fmtTime = (sec) => {
      if (sec >= 3600) { const h = Math.floor(sec / 3600); const m = Math.round((sec % 3600) / 60); return `≈ ${h}h ${m}m`; }
      if (sec >= 90) return `≈ ${Math.round(sec / 60)} min`;
      return `≈ ${Math.round(sec)} sec`;
    };

    function renderPlan() {
      const mbps = Number(slider.value);
      const mbsVal = mbps / 8;
      label.textContent = mbps >= 1000 ? "1 Gbps" : mbps + " Mbps";
      pxMbs.textContent = Number(mbsVal.toFixed(2)).toLocaleString();
      pxMin.textContent = fmtSize(mbsVal * 60);
      pxHr.textContent = ((mbsVal * 3600) / 1000).toFixed(1).replace(/\.0$/, "") + " GB";
      pxGame.textContent = fmtTime((75 * 1000) / mbsVal);
    }
    slider.addEventListener("input", renderPlan);
    renderPlan();
  </script>
