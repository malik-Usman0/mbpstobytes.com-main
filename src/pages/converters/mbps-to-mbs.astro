---
import Layout from '@theme/layouts/Layout.astro';
import RelatedTools from '@theme/components/RelatedTools.astro';

const title = 'Mbps to MB/s Converter – Megabits to Megabytes per Second';
const description =
  'Convert Mbps to MB/s instantly: 100 Mbps = 12.5 MB/s. Free megabit to megabyte per second calculator with plan comparison, download times, and MiB/s support.';

const siteURL = 'https://www.mbpstobytes.com';
const pageURL = `${siteURL}/converters/mbps-to-mbs/`;

const faqs = [
  {
    question: 'Is 100 Mbps the same as 100 MB/s?',
    answer:
      'No. 100 Mbps equals 12.5 MB/s, because a megabit is 8 times smaller than a megabyte. Mbps (megabits per second) measures your connection in bits; MB/s (megabytes per second) measures file transfer in bytes. A true 100 MB/s connection would be an 800 Mbps plan.',
  },
  {
    question: 'How many MB/s is 100 Mbps?',
    answer:
      '100 Mbps = 12.5 MB/s. Divide any Mbps value by 8 to get MB/s: 100 ÷ 8 = 12.5. In practice you will see slightly less (about 11–12 MB/s) due to protocol overhead.',
  },
  {
    question: 'How many MB/s is 300 Mbps?',
    answer:
      '300 Mbps = 37.5 MB/s (300 ÷ 8 = 37.5). At that rate you download about 2.25 GB per minute — a 75 GB game in roughly 27 minutes under ideal conditions.',
  },
  {
    question: 'Why do ISPs advertise in Mbps instead of MB/s?',
    answer:
      'Two reasons. Historically, telecommunications has always measured transmission in bits per second, so networking kept the convention. Practically, the bit number is 8× bigger — "100 Mbps" sounds more impressive than "12.5 MB/s" on marketing material, even though they are identical speeds.',
  },
  {
    question: 'Is 12.5 MB/s a good download speed?',
    answer:
      'Yes for most uses. 12.5 MB/s (a 100 Mbps plan) supports four simultaneous 4K streams and downloads a 5 GB file in about 7 minutes. Heavy downloaders — for example 75+ GB games — benefit from faster plans: at 62.5 MB/s (500 Mbps) the same game takes about 20 minutes.',
  },
  {
    question: 'Why does Steam show MB/s while my plan says Mbps?',
    answer:
      'Steam measures actual file data written to your disk, which is counted in bytes, so it reports MB/s. Multiply the Steam number by 8 to compare with your plan: 12.5 MB/s in Steam = 100 Mbps of bandwidth being used.',
  },
  {
    question: 'What is the difference between MB/s and MiB/s?',
    answer:
      'MB/s uses decimal megabytes (1 MB = 1,000,000 bytes); MiB/s uses binary mebibytes (1 MiB = 1,048,576 bytes). 100 Mbps = 12.5 MB/s but only 11.92 MiB/s. Some applications label MiB/s as "MB/s", which makes downloads look about 5% slower than they are. Our calculator supports both — use the SI/IEC toggle.',
  },
  {
    question: 'Why is my real download speed lower than Mbps ÷ 8?',
    answer:
      'The ÷8 conversion gives the theoretical maximum. Real downloads lose 5–15% to TCP/IP protocol overhead, Wi-Fi signal loss, server-side limits, and network congestion. On a 100 Mbps plan, sustained downloads of 11–12 MB/s over ethernet are normal and healthy.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Converters', item: `${siteURL}/converters/` },
    { '@type': 'ListItem', position: 3, name: 'Mbps to MB/s Converter', item: pageURL },
  ],
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${pageURL}#webapplication`,
  name: 'Mbps to MB/s Converter',
  url: pageURL,
  description,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  browserRequirements: 'Requires JavaScript',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', '@id': `${siteURL}#organization` },
  inLanguage: 'en',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

// Common plan values — rendered as crawlable anchor sections
const commonValues = [
  { mbps: 25, mbs: '3.125', perMin: '187.5 MB', game5gb: '≈ 27 min', note: 'Entry plans; one 4K stream (Netflix asks ~25 Mbps)' },
  { mbps: 50, mbs: '6.25', perMin: '375 MB', game5gb: '≈ 13 min', note: 'Comfortable for small households' },
  { mbps: 100, mbs: '12.5', perMin: '750 MB', game5gb: '≈ 7 min', note: 'The most common plan speed worldwide' },
  { mbps: 200, mbs: '25', perMin: '1.5 GB', game5gb: '≈ 3.5 min', note: 'Multi-user households, frequent downloads' },
  { mbps: 300, mbs: '37.5', perMin: '2.25 GB', game5gb: '≈ 2.2 min', note: 'Fiber mid-tier; heavy streaming + gaming' },
  { mbps: 500, mbs: '62.5', perMin: '3.75 GB', game5gb: '≈ 80 sec', note: 'Power users and large families' },
  { mbps: 900, mbs: '112.5', perMin: '6.75 GB', game5gb: '≈ 45 sec', note: 'Common "gigabit" real-world provisioning' },
  { mbps: 1000, mbs: '125', perMin: '7.5 GB', game5gb: '≈ 40 sec', note: 'Full gigabit fiber' },
];
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-400">
    <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/converters/" class="hover:text-indigo-600 transition-colors">Converters</a>
    <span class="mx-2">/</span>
    <span class="text-gray-600 font-medium">Mbps to MB/s Converter</span>
  </nav>

  <div class="gap-8 grid grid-cols-1 lg:grid-cols-3">
    <!-- Calculator card -->
    <section class="lg:col-span-2">
      <div class="premium-card">
        <div class="premium-card-inner">
          <div class="flex flex-wrap justify-between items-start gap-6 mb-8">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 rounded-full mb-3">
                <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                <span class="text-indigo-600 text-xs font-semibold uppercase tracking-wide">Live Calculator</span>
              </div>
              <h1 class="font-extrabold text-3xl md:text-4xl text-gray-900 tracking-tight">Mbps to MB/s Converter</h1>
              <p class="text-gray-500 text-base mt-3 max-w-lg leading-relaxed">
                Turn your internet plan's megabits per second into the megabytes per second your downloads actually show — in real time.
              </p>
            </div>
            <div class="flex items-center gap-2 bg-gray-50 px-4 py-3 rounded-2xl border border-gray-100">
              <span class="text-gray-500 text-sm font-medium">Decimals:</span>
              <button id="dec-minus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">−</button>
              <div id="dec-value" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 text-white font-bold text-sm shadow-lg shadow-indigo-200">2</div>
              <button id="dec-plus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">+</button>
            </div>
          </div>

          <!-- Unit standard toggle -->
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="text-gray-500 text-sm font-medium">Standard:</span>
            <div class="inline-flex rounded-xl border border-gray-200 bg-gray-50 p-1" role="group" aria-label="Unit standard">
              <button id="std-si" type="button" aria-pressed="true" class="px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200">MB/s (SI)</button>
              <button id="std-iec" type="button" aria-pressed="false" class="px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200">MiB/s (IEC)</button>
            </div>
            <span id="std-hint" class="text-gray-400 text-xs">1 MB = 1,000,000 bytes · MB/s = Mbps ÷ 8</span>
          </div>

          <!-- Form -->
          <div class="gap-8 grid md:grid-cols-2">
            <!-- Mbps side -->
            <div class="space-y-3">
              <label for="mbps" class="block text-gray-700 text-sm font-semibold">Internet speed (Mbps)</label>
              <div class="relative">
                <input id="mbps" inputmode="decimal" placeholder="Enter speed in Mbps" class="glow-input pr-16" />
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-teal-500 font-bold text-sm">Mbps</div>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">The number on your internet plan or speed test result.</p>
            </div>

            <!-- MB/s side -->
            <div class="space-y-3">
              <label for="mbs" class="block text-gray-700 text-sm font-semibold">Download speed (<span id="mbs-unit-label">MB/s</span>)</label>
              <div class="relative">
                <input id="mbs" inputmode="decimal" placeholder="Enter speed in MB/s" class="glow-input pr-16" />
                <div id="mbs-unit-badge" class="absolute right-5 top-1/2 -translate-y-1/2 text-amber-500 font-bold text-sm">MB/s</div>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">The number your browser, Steam, or download manager shows.</p>
            </div>
          </div>

          <!-- Preset chips -->
          <div class="flex flex-wrap items-center gap-2 mt-6" aria-label="Common plan speeds">
            <span class="text-gray-400 text-xs font-medium mr-1">Try a plan:</span>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-mbps="25">25 Mbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-mbps="100">100 Mbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-mbps="300">300 Mbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-mbps="500">500 Mbps</button>
            <button class="preset-chip px-4 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700 text-sm font-semibold hover:bg-teal-100 transition-colors" data-mbps="1000">1 Gbps</button>
          </div>

          <!-- Actions -->
          <div class="gap-4 grid grid-cols-1 sm:grid-cols-3 mt-8">
            <button id="btn-share" class="btn-premium btn-secondary flex justify-center items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              Share result
            </button>
            <button id="btn-reload" class="btn-premium btn-primary">Reload calculator</button>
            <button id="btn-clear" class="btn-premium btn-ghost" disabled>Clear all</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <div class="premium-card">
        <div class="premium-card-inner">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg shadow-indigo-200">
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
            <span class="text-gray-900 font-bold text-lg">Result</span>
          </div>
          <div id="result-main" class="result-display mb-3">—</div>
          <div id="result-secondary" class="text-gray-500 text-sm mb-6"></div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent my-6"></div>

          <div class="space-y-4">
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">Mbps:</span><span id="out-mbps" class="text-teal-600 font-semibold">—</span></div>
            <div class="flex justify-between items-center"><span id="lbl-mbs" class="text-gray-400 text-sm font-medium">MB/s:</span><span id="out-mbs" class="text-amber-600 font-semibold">—</span></div>
            <div class="flex justify-between items-center"><span id="lbl-kbs" class="text-gray-400 text-sm font-medium">KB/s:</span><span id="out-kbs" class="text-gray-600 font-semibold">—</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">MB per minute:</span><span id="out-mbmin" class="text-gray-600 font-semibold">—</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-400 text-sm font-medium">GB per hour:</span><span id="out-gbhr" class="text-gray-600 font-semibold">—</span></div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <!-- Quick answer -->
  <article class="premium-card mt-12">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">How Many MB/s Is 1 Mbps?</h2>
      <div class="p-6 rounded-2xl bg-gradient-to-r from-indigo-50 via-purple-50 to-pink-50 border-l-4 border-indigo-500 mb-8">
        <p class="text-lg text-gray-700">
          1 Mbps equals <strong class="text-indigo-600 text-xl">0.125 MB/s</strong>. To convert Mbps to MB/s, <strong>divide by 8</strong> — so a 100 Mbps internet plan downloads at a maximum of <strong class="text-indigo-600">12.5 MB/s</strong>.
        </p>
        <p class="text-gray-500 text-sm mt-2">MB/s = Mbps ÷ 8 &nbsp;·&nbsp; Mbps = MB/s × 8</p>
      </div>

      <p class="text-gray-600 leading-relaxed mb-6">
        The two units describe the same data stream at different granularity. <strong>Mbps</strong> counts individual <em>bits</em> — the convention used by internet providers, speed tests, and all networking equipment. <strong>MB/s</strong> counts <em>bytes</em> — groups of 8 bits — which is how files are measured, so browsers, Steam, and download managers report in it. Neither number is wrong; the byte number is simply 8× smaller because each of its units is 8× bigger.
      </p>

      <h3 class="font-semibold text-gray-900 mb-4">The ÷8 Rule, Visualized</h3>
      <div class="p-6 rounded-2xl bg-gradient-to-br from-teal-50 via-white to-amber-50 border-2 border-gray-100 mb-6" role="img" aria-label="100 Mbps shown as a long bar equals 12.5 MB/s shown as a bar one-eighth the length">
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="font-semibold text-teal-700">Your plan: 100 Mbps</span><span class="text-gray-400 text-xs">bits per second</span></div>
            <div class="h-6 rounded-full bg-gradient-to-r from-teal-400 to-teal-500 shadow-sm" style="width: 100%"></div>
          </div>
          <div class="text-center text-gray-400 font-bold text-sm">same speed, different unit — ÷ 8</div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="font-semibold text-amber-700">Your download: 12.5 MB/s</span><span class="text-gray-400 text-xs">bytes per second</span></div>
            <div class="h-6 rounded-full bg-gradient-to-r from-amber-400 to-amber-500 shadow-sm" style="width: 12.5%"></div>
          </div>
        </div>
        <p class="text-gray-400 text-xs mt-4 text-center">The bars represent the same physical speed. The MB/s bar looks 8× shorter only because each megabyte is 8× larger than a megabit.</p>
      </div>
    </div>
  </article>

  <!-- Common values (anchor sections) -->
  <section class="premium-card mt-8" id="common-speeds">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-2">Common Internet Plans in MB/s</h2>
      <p class="text-gray-500 mb-8">Every popular plan speed converted — with what it means for real downloads. All values use decimal (SI) units; real-world speeds run 5–15% lower due to overhead.</p>

      <div class="grid sm:grid-cols-2 gap-4">
        {
          commonValues.map((v) => (
            <div id={`${v.mbps}-mbps`} class="p-5 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100 hover:border-indigo-200 transition-colors">
              <div class="flex items-baseline justify-between mb-2">
                <h3 class="font-bold text-gray-900 text-lg">{v.mbps} Mbps = {v.mbs} MB/s</h3>
              </div>
              <ul class="text-sm text-gray-500 space-y-1">
                <li><span class="text-gray-400">Downloads per minute:</span> <strong class="text-gray-700">{v.perMin}</strong></li>
                <li><span class="text-gray-400">5 GB file:</span> <strong class="text-gray-700">{v.game5gb}</strong></li>
                <li class="text-gray-500 pt-1">{v.note}</li>
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Conversion tables -->
  <section class="premium-card mt-8">
    <div class="premium-card-inner">
      <div class="flex md:flex-row flex-col md:justify-between md:items-center gap-4 mb-8">
        <h2 class="font-bold text-2xl text-gray-900">Mbps to MB/s Conversion Table</h2>
        <p class="text-gray-400 text-sm font-medium">Formula: <span class="text-gray-600">MB/s = Mbps ÷ 8</span></p>
      </div>

      <div class="gap-8 grid md:grid-cols-2">
        <div>
          <h3 class="mb-4 font-semibold text-gray-700">Mbps to MB/s</h3>
          <div class="rounded-2xl border border-gray-100 overflow-hidden shadow-sm">
            <table class="luxury-table">
              <thead>
                <tr><th>Mbps</th><th>MB/s</th><th>MiB/s</th></tr>
              </thead>
              <tbody>
                <tr><td class="text-teal-600 font-semibold">1 Mbps</td><td class="text-amber-600 font-bold">0.125 MB/s</td><td class="text-gray-500">0.119 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">5 Mbps</td><td class="text-amber-600">0.625 MB/s</td><td class="text-gray-500">0.596 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">10 Mbps</td><td class="text-amber-600">1.25 MB/s</td><td class="text-gray-500">1.19 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">25 Mbps</td><td class="text-amber-600">3.125 MB/s</td><td class="text-gray-500">2.98 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">50 Mbps</td><td class="text-amber-600">6.25 MB/s</td><td class="text-gray-500">5.96 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">100 Mbps</td><td class="text-amber-600 font-bold">12.5 MB/s</td><td class="text-gray-500">11.92 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">200 Mbps</td><td class="text-amber-600">25 MB/s</td><td class="text-gray-500">23.84 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">300 Mbps</td><td class="text-amber-600">37.5 MB/s</td><td class="text-gray-500">35.76 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">500 Mbps</td><td class="text-amber-600">62.5 MB/s</td><td class="text-gray-500">59.60 MiB/s</td></tr>
                <tr><td class="text-teal-600 font-semibold">1,000 Mbps</td><td class="text-amber-600 font-bold">125 MB/s</td><td class="text-gray-500">119.21 MiB/s</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <h3 class="mb-4 font-semibold text-gray-700">MB/s to Mbps</h3>
          <div class="rounded-2xl border border-gray-100 overflow-hidden shadow-sm">
            <table class="luxury-table">
              <thead>
                <tr><th>MB/s</th><th>Mbps</th><th>Typical context</th></tr>
              </thead>
              <tbody>
                <tr><td class="text-amber-600 font-semibold">0.5 MB/s</td><td class="text-teal-600">4 Mbps</td><td class="text-gray-500">SD video stream</td></tr>
                <tr><td class="text-amber-600 font-semibold">1 MB/s</td><td class="text-teal-600 font-bold">8 Mbps</td><td class="text-gray-500">HD video stream</td></tr>
                <tr><td class="text-amber-600 font-semibold">3.125 MB/s</td><td class="text-teal-600">25 Mbps</td><td class="text-gray-500">4K stream (Netflix)</td></tr>
                <tr><td class="text-amber-600 font-semibold">5 MB/s</td><td class="text-teal-600">40 Mbps</td><td class="text-gray-500">Cloud game stream</td></tr>
                <tr><td class="text-amber-600 font-semibold">10 MB/s</td><td class="text-teal-600">80 Mbps</td><td class="text-gray-500">Fast Steam download</td></tr>
                <tr><td class="text-amber-600 font-semibold">12.5 MB/s</td><td class="text-teal-600 font-bold">100 Mbps</td><td class="text-gray-500">Full 100 Mbps plan</td></tr>
                <tr><td class="text-amber-600 font-semibold">25 MB/s</td><td class="text-teal-600">200 Mbps</td><td class="text-gray-500">Mid fiber plan</td></tr>
                <tr><td class="text-amber-600 font-semibold">62.5 MB/s</td><td class="text-teal-600">500 Mbps</td><td class="text-gray-500">Fast fiber plan</td></tr>
                <tr><td class="text-amber-600 font-semibold">125 MB/s</td><td class="text-teal-600">1,000 Mbps</td><td class="text-gray-500">Gigabit fiber</td></tr>
                <tr><td class="text-amber-600 font-semibold">250 MB/s</td><td class="text-teal-600">2,000 Mbps</td><td class="text-gray-500">Multi-gig fiber</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <p class="mt-8 text-gray-400 text-sm">MiB/s values use the binary (IEC) standard: 1 MiB = 1,048,576 bytes. Windows and some apps display MiB/s but label it "MB/s" — see the section below.</p>
    </div>
  </section>

  <!-- How to convert -->
  <article class="premium-card mt-8">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">How to Convert Mbps to MB/s</h2>

      <p class="text-gray-600 leading-relaxed mb-6">
        To convert megabits per second to megabytes per second, <strong class="text-indigo-600">divide the Mbps value by 8</strong>. That's the whole conversion — because 1 byte = 8 bits by definition, and both units use the same decimal "mega" prefix (1,000,000).
      </p>

      <h3 class="font-semibold text-gray-900 mb-4">Step-by-Step Example</h3>
      <div class="space-y-3 mb-8">
        <div class="flex gap-3 items-start">
          <span class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 font-bold text-sm flex items-center justify-center flex-shrink-0">1</span>
          <span class="text-gray-600">Take your plan speed: <strong>300 Mbps</strong></span>
        </div>
        <div class="flex gap-3 items-start">
          <span class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 font-bold text-sm flex items-center justify-center flex-shrink-0">2</span>
          <span class="text-gray-600">Divide by 8: 300 ÷ 8 = <strong class="text-indigo-600">37.5 MB/s</strong></span>
        </div>
        <div class="flex gap-3 items-start">
          <span class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 font-bold text-sm flex items-center justify-center flex-shrink-0">3</span>
          <span class="text-gray-600">Sanity-check against reality: expect sustained downloads of ~33–36 MB/s after 5–15% overhead</span>
        </div>
      </div>

      <h3 class="font-semibold text-gray-900 mb-4">Formula Summary</h3>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-2xl bg-gradient-to-br from-teal-50 to-white border border-teal-100">
          <p class="text-xs text-teal-600 font-medium mb-1">Mbps to MB/s</p>
          <code class="text-teal-700 text-sm font-semibold">MB/s = Mbps ÷ 8</code>
        </div>
        <div class="p-4 rounded-2xl bg-gradient-to-br from-amber-50 to-white border border-amber-100">
          <p class="text-xs text-amber-600 font-medium mb-1">MB/s to Mbps</p>
          <code class="text-amber-700 text-sm font-semibold">Mbps = MB/s × 8</code>
        </div>
        <div class="p-4 rounded-2xl bg-gradient-to-br from-gray-50 to-white border border-gray-100">
          <p class="text-xs text-gray-500 font-medium mb-1">Mbps to MiB/s (binary)</p>
