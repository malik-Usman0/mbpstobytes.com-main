  </section>

  <RelatedTools
    tools={[
      {
        name: 'MB to GB Converter',
        url: '/converters/mb-to-gb/',
        description: 'The next step up the ladder — megabytes to gigabytes, both standards side by side.',
        icon: '💾',
      },
      {
        name: 'Download Time Calculator',
        url: '/tools/download-time-calculator/',
        description: 'How long will that file take to send or download at your speed?',
        icon: '⏱️',
      },
      {
        name: 'All Converters & Tools',
        url: '/converters/',
        description: 'Browse every data converter and calculator on the site.',
        icon: '🧰',
      },
    ]}
  />

  <!-- Calculator Logic -->
  <script is:inline>
    const el = (id) => document.getElementById(id);
    const $kb = el("kb");
    const $mb = el("mb");
    const $stdSi = el("std-si");
    const $stdIec = el("std-iec");
    const $stdHint = el("std-hint");
    const $kbLabel = el("kb-label");
    const $mbLabel = el("mb-label");
    const $kbBadge = el("kb-badge");
    const $mbBadge = el("mb-badge");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $outMb = el("out-mb");
    const $outMib = el("out-mib");
    const $outBytes = el("out-bytes");
    const $outEmail = el("out-email");
    const $outUl = el("out-ul");

    let state = { lastEdited: "kb", standard: "si", decimals: 3 };

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const fmt = (n) => (Number.isFinite(n) ? Number(n.toFixed(state.decimals)).toLocaleString() : "—");
    const factor = () => (state.standard === "iec" ? 1024 : 1000);
    const kbUnit = () => (state.standard === "iec" ? "KiB" : "KB");
    const mbUnit = () => (state.standard === "iec" ? "MiB" : "MB");

    const refreshUI = () => {
      const si = state.standard === "si";
      const on = "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200";
      const off = "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdSi.className = si ? on : off;
      $stdIec.className = !si ? on : off;
      $stdSi.setAttribute("aria-pressed", String(si));
      $stdIec.setAttribute("aria-pressed", String(!si));
      $stdHint.textContent = si ? "1 MB = 1,000 KB — the official decimal definition" : "1 MiB = 1,024 KiB — how Windows counts file sizes";
      $kbLabel.textContent = kbUnit(); $kbBadge.textContent = kbUnit();
      $mbLabel.textContent = mbUnit(); $mbBadge.textContent = mbUnit();
    };

    const fmtTime = (sec) => {
      if (!Number.isFinite(sec)) return "—";
      if (sec >= 60) { const m = Math.floor(sec/60); const s = Math.round(sec%60); return `≈ ${m}m ${s}s`; }
      if (sec >= 1) return `≈ ${Math.round(sec)}s`;
      return "under 1s";
    };

    const render = () => {
      let kbVal;
      if (state.lastEdited === "kb") {
        const k = num($kb.value);
        kbVal = Number.isFinite(k) && $kb.value !== "" ? k : NaN;
        $mb.value = Number.isFinite(kbVal) ? Number((kbVal / factor()).toFixed(Math.max(state.decimals, 6))).toString() : "";
      } else {
        const m = num($mb.value);
        kbVal = Number.isFinite(m) && $mb.value !== "" ? m * factor() : NaN;
        $kb.value = Number.isFinite(kbVal) ? Number(kbVal.toFixed(Math.max(state.decimals, 6))).toString() : "";
      }

      if (!Number.isFinite(kbVal)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$outMb, $outMib, $outBytes, $outEmail, $outUl].forEach((o) => (o.textContent = "—"));
        $decValue.textContent = state.decimals;
        return;
      }

      const bytes = state.standard === "iec" ? kbVal * 1024 : kbVal * 1000;
      const mbDec = bytes / 1e6;
      const mib = bytes / 1048576;
      const ulSec = (bytes * 8) / 10000000; // at 10 Mbps upload

      $resMain.textContent = state.lastEdited === "kb" ? fmt(kbVal / factor()) + " " + mbUnit() : fmt(kbVal) + " " + kbUnit();
      $resSecondary.textContent = fmt(kbVal) + " " + kbUnit() + " = " + fmt(kbVal / factor()) + " " + mbUnit() + (state.standard === "si" ? " (decimal)" : " (binary)");
      $outMb.textContent = fmt(mbDec);
      $outMib.textContent = fmt(mib);
      $outBytes.textContent = Math.round(bytes).toLocaleString();
      $outEmail.textContent = bytes <= 25000000 ? "✓ yes" : "✗ too big";
      $outUl.textContent = fmtTime(ulSec);
      $decValue.textContent = state.decimals;
    };

    $kb.addEventListener("input", () => { state.lastEdited = "kb"; render(); });
    $mb.addEventListener("input", () => { state.lastEdited = "mb"; render(); });
    $stdSi.addEventListener("click", () => { state.standard = "si"; refreshUI(); render(); });
    $stdIec.addEventListener("click", () => { state.standard = "iec"; refreshUI(); render(); });

    document.querySelectorAll(".preset-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        $kb.value = chip.dataset.kb;
        state.lastEdited = "kb";
        render();
      });
    });

    $decMinus.addEventListener("click", () => { state.decimals = Math.max(0, state.decimals - 1); render(); });
    $decPlus.addEventListener("click", () => { state.decimals = Math.min(10, state.decimals + 1); render(); });

    $btnShare.addEventListener("click", async () => {
      if ($resMain.textContent === "—") return;
      const txt = `KB↔MB: ${$kb.value} ${kbUnit()} = ${$mb.value} ${mbUnit()} (${state.standard === "si" ? "decimal" : "binary"}). via mbpstobytes.com/converters/kb-to-mb/`;
      try { await navigator.clipboard.writeText(txt); } catch (e) {}
    });

    $btnReload.addEventListener("click", () => window.location.reload());
    $btnClear.addEventListener("click", () => {
      $kb.value = "";
      $mb.value = "";
      state.lastEdited = "kb";
      render();
    });

    refreshUI();
    render();
  </script>
</Layout>
