  <RelatedTools
    tools={[
      {
        name: 'MB to GB Converter',
        url: '/converters/mb-to-gb/',
        description: 'One step down the ladder — megabytes to gigabytes with both standards side by side.',
        icon: '💾',
      },
      {
        name: 'Download Time Calculator',
        url: '/tools/download-time-calculator/',
        description: 'How long to fill or transfer a drive this size at your connection speed?',
        icon: '⏱️',
      },
      {
        name: 'All Converters & Tools',
        url: '/converters/',
        description: 'Browse every data converter and calculator on the site.',
        icon: '🧰',
      },
    ]}
  />

  <!-- Calculator Logic -->
  <script is:inline>
    const el = (id) => document.getElementById(id);
    const $gb = el("gb");
    const $tb = el("tb");
    const $stdSi = el("std-si");
    const $stdIec = el("std-iec");
    const $stdHint = el("std-hint");
    const $gbLabel = el("gb-label");
    const $tbLabel = el("tb-label");
    const $gbBadge = el("gb-badge");
    const $tbBadge = el("tb-badge");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $outTb = el("out-tb");
    const $outTib = el("out-tib");
    const $outWin = el("out-win");
    const $outMb = el("out-mb");
    const $outFill = el("out-fill");

    let state = { lastEdited: "gb", standard: "si", decimals: 3 };

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const fmt = (n) => (Number.isFinite(n) ? Number(n.toFixed(state.decimals)).toLocaleString() : "—");
    const factor = () => (state.standard === "iec" ? 1024 : 1000);
    const gbUnit = () => (state.standard === "iec" ? "GiB" : "GB");
    const tbUnit = () => (state.standard === "iec" ? "TiB" : "TB");

    const refreshUI = () => {
      const si = state.standard === "si";
      const on = "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200";
      const off = "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdSi.className = si ? on : off;
      $stdIec.className = !si ? on : off;
      $stdSi.setAttribute("aria-pressed", String(si));
      $stdIec.setAttribute("aria-pressed", String(!si));
      $stdHint.textContent = si ? "1 TB = 1,000 GB — what the box and the spec sheet mean" : "1 TiB = 1,024 GiB — how Windows counts drive space";
      $gbLabel.textContent = gbUnit(); $gbBadge.textContent = gbUnit();
      $tbLabel.textContent = tbUnit(); $tbBadge.textContent = tbUnit();
    };

    const fmtDur = (sec) => {
      if (!Number.isFinite(sec)) return "—";
      if (sec >= 86400) { const d2 = Math.floor(sec/86400); const h = Math.round((sec%86400)/3600); return `≈ ${d2}d ${h}h`; }
      if (sec >= 3600) { const h = Math.floor(sec/3600); const m = Math.round((sec%3600)/60); return `≈ ${h}h ${m}m`; }
      return `≈ ${Math.round(sec/60)}m`;
    };

    const winShow = (bytes) => {
      const tib = bytes / 1099511627776;
      if (tib >= 1) return "≈ " + Number(tib.toFixed(2)).toLocaleString() + " TB";
      const gib = bytes / 1073741824;
      return "≈ " + Math.round(gib).toLocaleString() + " GB";
    };

    const render = () => {
      let gbVal;
      if (state.lastEdited === "gb") {
        const g = num($gb.value);
        gbVal = Number.isFinite(g) && $gb.value !== "" ? g : NaN;
        $tb.value = Number.isFinite(gbVal) ? Number((gbVal / factor()).toFixed(Math.max(state.decimals, 6))).toString() : "";
      } else {
        const t = num($tb.value);
        gbVal = Number.isFinite(t) && $tb.value !== "" ? t * factor() : NaN;
        $gb.value = Number.isFinite(gbVal) ? Number(gbVal.toFixed(Math.max(state.decimals, 6))).toString() : "";
      }

      if (!Number.isFinite(gbVal)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$outTb, $outTib, $outWin, $outMb, $outFill].forEach((o) => (o.textContent = "—"));
        $decValue.textContent = state.decimals;
        return;
      }

      const bytes = state.standard === "iec" ? gbVal * 1073741824 : gbVal * 1e9;
      const tbDec = bytes / 1e12;
      const tib = bytes / 1099511627776;
      const mb = bytes / 1e6;
      const fillSec = (bytes * 8) / 100000000; // 100 Mbps

      $resMain.textContent = state.lastEdited === "gb" ? fmt(gbVal / factor()) + " " + tbUnit() : fmt(gbVal) + " " + gbUnit();
      $resSecondary.textContent = fmt(gbVal) + " " + gbUnit() + " = " + fmt(gbVal / factor()) + " " + tbUnit() + (state.standard === "si" ? " (decimal)" : " (binary)");
      $outTb.textContent = fmt(tbDec);
      $outTib.textContent = fmt(tib);
      $outWin.textContent = winShow(bytes);
      $outMb.textContent = Math.round(mb).toLocaleString();
      $outFill.textContent = fmtDur(fillSec);
      $decValue.textContent = state.decimals;
    };

    $gb.addEventListener("input", () => { state.lastEdited = "gb"; render(); });
    $tb.addEventListener("input", () => { state.lastEdited = "tb"; render(); });
    $stdSi.addEventListener("click", () => { state.standard = "si"; refreshUI(); render(); });
    $stdIec.addEventListener("click", () => { state.standard = "iec"; refreshUI(); render(); });

    document.querySelectorAll(".preset-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        $gb.value = chip.dataset.gb;
        state.lastEdited = "gb";
        render();
      });
    });

    $decMinus.addEventListener("click", () => { state.decimals = Math.max(0, state.decimals - 1); render(); });
    $decPlus.addEventListener("click", () => { state.decimals = Math.min(10, state.decimals + 1); render(); });

    $btnShare.addEventListener("click", async () => {
      if ($resMain.textContent === "—") return;
      const txt = `GB↔TB: ${$gb.value} ${gbUnit()} = ${$tb.value} ${tbUnit()} (${state.standard === "si" ? "decimal" : "binary"}). via mbpstobytes.com/converters/gb-to-tb/`;
      try { await navigator.clipboard.writeText(txt); } catch (e) {}
    });

    $btnReload.addEventListener("click", () => window.location.reload());
    $btnClear.addEventListener("click", () => {
      $gb.value = "";
      $tb.value = "";
      state.lastEdited = "gb";
      render();
    });

    refreshUI();
    render();
  </script>
</Layout>
