---
import Layout from '@theme/layouts/Layout.astro';
import ToolsGrid from '@theme/components/ToolsGrid.astro';
import toolsConfig from '~/config/tools.json';

const title = 'Data Unit Converters – Mbps, MB/s, Bytes & More';
const description =
  'Free data-rate converters and calculators: Mbps to Bytes, Bytes to Mbps, and more. Real-time results, SI/IEC standards, conversion tables and formulas.';

const siteURL = 'https://www.mbpstobytes.com';
const pageURL = `${siteURL}/converters/`;

const allTools = toolsConfig.categories.flatMap((c) => c.tools);

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${pageURL}#collectionpage`,
  name: title,
  url: pageURL,
  description,
  hasPart: allTools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.name,
    url: `${siteURL}${tool.url}`,
    description: tool.description,
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteURL}/` },
    { '@type': 'ListItem', position: 2, name: 'Converters', item: pageURL },
  ],
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-400">
    <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <span class="text-gray-600 font-medium">Converters</span>
  </nav>

  <div class="text-center max-w-3xl mx-auto mb-4">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 rounded-full mb-4">
      <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
      <span class="text-indigo-600 text-xs font-semibold uppercase tracking-wide">Free Tools</span>
    </div>
    <h1 class="font-extrabold text-3xl md:text-4xl text-gray-900 tracking-tight">Data Unit Converters</h1>
    <p class="text-gray-500 text-base mt-4 leading-relaxed">
      Every tool on this page converts between the two ways the digital world measures data: <strong>bits</strong> (used by networks and internet plans) and <strong>bytes</strong> (used by files, apps and operating systems). All calculators run in real time, support decimal (SI) and binary (IEC) standards where relevant, and follow our published
      <a href="/methodology/" class="text-indigo-600 hover:underline font-medium">calculation methodology</a>.
    </p>
  </div>

  <ToolsGrid title="Speed Converters" subtitle="Pick the conversion you need — results update as you type." onlyCategories={['Speed Converters']} />

  <!-- Why two unit systems -->
  <article class="premium-card mt-12">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">Bits vs Bytes: Which Tool Do You Need?</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        The rule of thumb: if the number comes from your <strong>internet provider or a speed test</strong>, it's in bits (Mbps). If it comes from a <strong>download bar, file manager, or app</strong>, it's in bytes (MB/s, KB/s). Since 1 byte = 8 bits, the bit number is always 8× larger than the byte number for the same real speed.
      </p>
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="p-5 rounded-2xl bg-gradient-to-br from-teal-50 to-white border border-teal-100">
          <h3 class="font-semibold text-gray-900 mb-2">Start from your internet plan (Mbps)?</h3>
          <p class="text-gray-500 text-sm mb-3">Convert the advertised speed into the download speed you'll actually see.</p>
          <a href="/" class="text-indigo-600 text-sm font-semibold hover:underline">→ Mbps to Bytes Converter</a>
        </div>
        <div class="p-5 rounded-2xl bg-gradient-to-br from-amber-50 to-white border border-amber-100">
          <h3 class="font-semibold text-gray-900 mb-2">Start from an app's speed (MB/s, KB/s)?</h3>
          <p class="text-gray-500 text-sm mb-3">Check how much of your plan's bandwidth a download is really using.</p>
          <a href="/converters/bytes-to-mbps/" class="text-indigo-600 text-sm font-semibold hover:underline">→ Bytes to Mbps Converter</a>
        </div>
        <div class="p-5 rounded-2xl bg-gradient-to-br from-indigo-50 to-white border border-indigo-100">
          <h3 class="font-semibold text-gray-900 mb-2">Comparing internet plans (Mbps vs MB/s)?</h3>
          <p class="text-gray-500 text-sm mb-3">See the real download speed behind every plan tier, from 25 Mbps to gigabit.</p>
          <a href="/converters/mbps-to-mbs/" class="text-indigo-600 text-sm font-semibold hover:underline">→ Mbps to MB/s Converter</a>
        </div>
      </div>
      <p class="text-gray-400 text-sm mt-6">
        More converters are on the way: storage pairs (MB ⇄ GB, GB ⇄ TB) and the bits ⇄ bytes fundamentals launch next. Looking for practical calculators instead — download time, packets per second? Visit our <a href="/tools/" class="text-indigo-600 hover:underline font-medium">Network Tools & Calculators</a>.
      </p>
    </div>
  </article>
</Layout>
