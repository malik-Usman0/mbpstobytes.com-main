---
import IndexLayout, { getStaticPaths as getStaticPathsIndex } from "@theme/layouts/IndexLayout.astro";
import FAQs from "@theme/components/FAQs.astro";
import Chart from "@theme/components/Chart.astro";
import { getTranslations, type Locale } from "@theme/i18n/utils";
import HowItWorks from "@theme/components/HowItWorks.astro";
import ToolsGrid from "@theme/components/ToolsGrid.astro";

const locale = (Astro.params.lang || "en") as Locale;
const t = getTranslations(locale);

export const getStaticPaths = getStaticPathsIndex;
---

<IndexLayout>
  <div class="gap-8 grid grid-cols-1 lg:grid-cols-3">
    <!-- Calculator card -->
    <section class="lg:col-span-2">
      <div class="premium-card">
        <div class="premium-card-inner">
          <!-- Header -->
          <div class="flex flex-wrap justify-between items-start gap-6 mb-8">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 rounded-full mb-3">
                <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                <span class="text-indigo-600 text-xs font-semibold uppercase tracking-wide">Live Calculator</span>
              </div>
              <h1 class="font-extrabold text-3xl md:text-4xl text-gray-900 tracking-tight">
                {t["Mbps to Bytes Converter"]}
              </h1>
              <p class="text-gray-500 text-base mt-3 max-w-lg leading-relaxed">
                {t["Convert between Mbps and Bytes/s in real time. No buttons — results update as you type."]}
              </p>
            </div>
            <div class="flex items-center gap-2 bg-gray-50 px-4 py-3 rounded-2xl border border-gray-100">
              <span class="text-gray-500 text-sm font-medium">{t["Decimals:"]}</span>
              <button id="dec-minus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">−</button>
              <div id="dec-value" class="w-9 h-9 flex items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 text-white font-bold text-sm shadow-lg shadow-indigo-200">2</div>
              <button id="dec-plus" class="w-9 h-9 rounded-xl border border-gray-200 bg-white text-gray-400 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-300 flex items-center justify-center font-bold">+</button>
            </div>
          </div>

          <!-- INTERACTIVE CONVERSION VISUALIZATION - FIXED LAYOUT -->
          <div class="mb-10 p-6 md:p-8 rounded-3xl bg-gradient-to-br from-teal-50 via-white to-amber-50 border-2 border-gray-100 shadow-inner relative overflow-hidden">
            <!-- Decorative elements -->
            <div class="absolute top-4 right-4 w-20 h-20 bg-gradient-to-br from-teal-200 to-teal-100 rounded-full blur-2xl opacity-60"></div>
            <div class="absolute bottom-4 left-4 w-24 h-24 bg-gradient-to-br from-amber-200 to-amber-100 rounded-full blur-2xl opacity-60"></div>

            <div class="text-center mb-6 relative">
              <p class="text-gray-700 text-sm font-bold uppercase tracking-wide mb-1">Live Conversion Visualization</p>
              <p class="text-gray-400 text-xs">Watch 8 bits combine into 1 byte</p>
            </div>

            <!-- Main Visualization Area - FLEXBOX LAYOUT -->
            <div class="relative rounded-2xl viz-container p-6 md:p-8" id="conversion-viz">
              <!-- Canvas for particle effects -->
              <canvas id="particle-canvas" class="absolute inset-0 w-full h-full rounded-2xl pointer-events-none"></canvas>

              <!-- Flexbox Layout for proper spacing -->
              <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6 md:gap-4">
                <!-- Bits Section (Left) -->
                <div class="flex flex-col items-center text-center">
                  <div class="text-teal-600 font-extrabold text-2xl md:text-3xl mb-1" id="mbps-display">0</div>
                  <div class="text-teal-500 text-xs font-bold uppercase tracking-wide mb-3">Mbps</div>
                  <div class="flex gap-1" id="bits-container">
                    <div class="bit-box" data-bit="0">0</div>
                    <div class="bit-box" data-bit="1">1</div>
                    <div class="bit-box" data-bit="2">0</div>
                    <div class="bit-box" data-bit="3">1</div>
                    <div class="bit-box" data-bit="4">0</div>
                    <div class="bit-box" data-bit="5">1</div>
                    <div class="bit-box" data-bit="6">0</div>
                    <div class="bit-box" data-bit="7">1</div>
                  </div>
                  <div class="text-gray-400 text-[10px] mt-2 font-medium">8 bits = 1 byte</div>
                </div>

                <!-- Conversion Symbol (Center) -->
                <div class="flex flex-col items-center flex-shrink-0">
                  <div class="w-14 h-14 md:w-16 md:h-16 rounded-2xl bg-white shadow-xl border-2 border-gray-100 flex items-center justify-center">
                    <span class="text-xl md:text-2xl font-black bg-gradient-to-br from-indigo-600 to-purple-600 bg-clip-text text-transparent">÷8</span>
                  </div>
                  <div class="hidden md:flex items-center gap-2 mt-2">
                    <div class="w-8 h-0.5 bg-gradient-to-r from-teal-400 to-transparent rounded-full"></div>
                    <svg class="w-5 h-5 text-amber-500" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M13.025 1l-2.847 2.828 6.176 6.176H0v3.992h16.354l-6.176 6.176L13.025 23 24 12z"></path>
                    </svg>
                    <div class="w-8 h-0.5 bg-gradient-to-l from-amber-400 to-transparent rounded-full"></div>
                  </div>
                </div>

                <!-- Bytes Section (Right) -->
                <div class="flex flex-col items-center text-center">
                  <div class="text-amber-600 font-extrabold text-2xl md:text-3xl mb-1" id="bytes-display">0</div>
                  <div class="text-amber-500 text-xs font-bold uppercase tracking-wide mb-3">B/s</div>
                  <div id="byte-container">
                    <div class="byte-box" id="byte-result">
                      <span class="text-sm font-black">BYTE</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Speed Indicator Bar -->
            <div class="mt-6 relative">
              <div class="flex justify-between text-xs text-gray-400 mb-2 font-medium">
                <span>0 Mbps</span>
                <span class="text-gray-500 font-semibold">Transfer Speed</span>
                <span>1000 Mbps</span>
              </div>
              <div class="speed-track">
                <div id="speed-bar" class="h-full rounded-full bg-gradient-to-r from-teal-400 via-indigo-500 to-pink-500 transition-all duration-500 shadow-lg" style="width: 0%"></div>
              </div>
            </div>
          </div>

          <!-- Unit standard toggle -->
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="text-gray-500 text-sm font-medium">Standard:</span>
            <div class="inline-flex rounded-xl border border-gray-200 bg-gray-50 p-1" role="group" aria-label="Unit standard">
              <button id="std-si" type="button" aria-pressed="true" class="px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200">Decimal (SI)</button>
              <button id="std-iec" type="button" aria-pressed="false" class="px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200">Binary (IEC)</button>
            </div>
            <span id="std-hint" class="text-gray-400 text-xs">1 KB = 1,000 B · 1 MB = 1,000,000 B</span>
          </div>

          <!-- Form -->
          <div class="gap-8 grid md:grid-cols-2">
            <!-- Mbps -->
            <div class="space-y-3">
              <label for="mbps" class="block text-gray-700 text-sm font-semibold">
                {t["Megabits per second (Mbps)"]}
              </label>
              <div class="relative">
                <input id="mbps" inputmode="decimal" placeholder={t["Enter speed in Mbps"]} class="glow-input pr-16" />
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-teal-500 font-bold text-sm">Mbps</div>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">
                {t["Network speeds are usually in Mbps (decimal): 1 Mbps = 1,000,000 bits per second."]}
              </p>
            </div>

            <!-- Bytes/s -->
            <div class="space-y-3">
              <label for="bytes" class="block text-gray-700 text-sm font-semibold">
                {t["Bytes per second (B/s)"]}
              </label>
              <div class="relative">
                <input id="bytes" inputmode="decimal" placeholder={t["Enter speed in Bytes/s"]} class="glow-input pr-24" />
                <select id="byte-unit" aria-label="Byte-side unit" class="absolute right-3 top-1/2 -translate-y-1/2 bg-amber-50 border border-amber-100 text-amber-600 font-bold text-sm rounded-lg px-2 py-1.5 cursor-pointer focus:outline-none focus:ring-2 focus:ring-amber-200">
                  <option value="B" selected>B/s</option>
                  <option value="KB">KB/s</option>
                  <option value="MB">MB/s</option>
                  <option value="GB">GB/s</option>
                </select>
              </div>
              <p class="text-gray-400 text-xs leading-relaxed">
                {t["1 byte = 8 bits. So Bytes/s = bits/s ÷ 8."]}
              </p>
            </div>
          </div>

          <!-- Actions -->
          <div class="gap-4 grid grid-cols-1 sm:grid-cols-3 mt-8">
            <button id="btn-share" class="btn-premium btn-secondary flex justify-center items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              {t["Share result"]}
            </button>
            <button id="btn-reload" class="btn-premium btn-primary">
              {t["Reload calculator"]}
            </button>
            <button id="btn-clear" class="btn-premium btn-ghost" disabled>
              {t["Clear all"]}
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <div class="premium-card">
        <div class="premium-card-inner">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg shadow-indigo-200">
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
            <span class="text-gray-900 font-bold text-lg">{t["Result"]}</span>
          </div>
          <div id="result-main" class="result-display mb-3">—</div>
          <div id="result-secondary" class="text-gray-500 text-sm mb-6"></div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent my-6"></div>

          <div class="space-y-4">
            <div id="result-mbps" class="flex justify-between items-center">
              <span class="text-gray-400 text-sm font-medium">{t["Mbps:"]}</span>
              <span class="text-gray-600 font-semibold">—</span>
            </div>
            <div id="result-bps" class="flex justify-between items-center">
              <span class="text-gray-400 text-sm font-medium">{t["Bytes/s:"]}</span>
              <span class="text-gray-600 font-semibold">—</span>
            </div>
            <div id="result-kbps" class="flex justify-between items-center">
              <span class="text-gray-400 text-sm font-medium">{t["KB/s:"]}</span>
              <span class="text-gray-600 font-semibold">—</span>
            </div>
            <div id="result-mBps" class="flex justify-between items-center">
              <span class="text-gray-400 text-sm font-medium">{t["MB/s:"]}</span>
              <span class="text-gray-600 font-semibold">—</span>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <!-- Trust strip -->
  <div class="mt-12 p-5 rounded-2xl bg-gradient-to-r from-indigo-50 to-white border-l-4 border-indigo-500">
    <p class="text-sm text-gray-500">
      ✓ <strong class="text-gray-600">Fact-checked:</strong> every conversion factor on this page follows
      <a href="https://physics.nist.gov/cuu/Units/binary.html" rel="noopener" target="_blank" class="text-indigo-600 hover:underline">NIST</a> and
      <a href="https://www.iec.ch/prefixes-binary-multiples" rel="noopener" target="_blank" class="text-indigo-600 hover:underline">IEC 80000-13</a> definitions — see our
      <a href="/methodology/" class="text-indigo-600 hover:underline">calculation methodology</a>. 🔄 <strong class="text-gray-600">Last reviewed:</strong> July 2026
    </p>
  </div>

  <!-- Quick Answer -->
  <article class="premium-card mt-8">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">Quick Answer: Mbps to Bytes</h2>
      <div class="p-6 rounded-2xl bg-gradient-to-r from-indigo-50 via-purple-50 to-pink-50 border-l-4 border-indigo-500">
        <p class="text-lg text-gray-700">
          To convert Mbps to Bytes per second, <strong class="text-indigo-600">multiply by 125,000</strong> — because 1 megabit is 1,000,000 bits and every byte holds 8 bits. So <strong class="text-indigo-600">1 Mbps = 125,000 B/s</strong>, and a 100 Mbps internet connection moves a maximum of 12,500,000 Bytes (12.5 MB) of data every second.
        </p>
        <p class="text-gray-500 text-sm mt-2">Bytes/s = Mbps × 1,000,000 ÷ 8 &nbsp;·&nbsp; works for any data transfer rate, upload or download</p>
      </div>
    </div>
  </article>

  <!-- What is Megabit Section -->
  <article class="premium-card mt-12">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">What is a Megabit?</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        A Megabit (Mb) is <strong class="text-indigo-600">a unit of digital information equal to 1,000,000 bits (10<sup>6</sup> bits)</strong> or 1,000 kilobits. Megabit has the symbol <strong>Mb</strong> and is one of the basic units in telecommunication and computer science for measuring digital information transmission.
      </p>

      <div class="grid sm:grid-cols-2 gap-6 mb-6">
        <div class="p-5 rounded-2xl bg-gradient-to-br from-teal-50 to-white border border-teal-100">
          <h3 class="font-semibold text-gray-900 mb-2">Megabit Key Facts</h3>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-teal-500 mt-1">•</span>
              <span>1 Megabit = 1,000,000 bits</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-teal-500 mt-1">•</span>
              <span>1 Megabit = 1,000 kilobits (Kb)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-teal-500 mt-1">•</span>
              <span>1 Megabit = 125,000 Bytes</span>
            </li>
          </ul>
        </div>
        <div class="p-5 rounded-2xl bg-gradient-to-br from-indigo-50 to-white border border-indigo-100">
          <h3 class="font-semibold text-gray-900 mb-2">Common Uses</h3>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-indigo-500 mt-1">•</span>
              <span>Internet speed measurement (Mbps)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-500 mt-1">•</span>
              <span>Network transfer rates</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-500 mt-1">•</span>
              <span>Bandwidth capacity</span>
            </li>
          </ul>
        </div>
      </div>

      <p class="text-gray-600 leading-relaxed">Internet Service Providers (ISPs) use Megabits per second (Mbps) to represent communication speed, including download speed, upload speed, and overall network speed. This unit measures the data transfer rate of your internet connection.</p>
    </div>
  </article>

  <!-- What is Byte Section -->
  <article class="premium-card mt-8">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">What is a Byte?</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        A Byte (B) is <strong class="text-amber-600">the basic unit of digital information storage consisting of 8 bits</strong>. The Byte is used extensively in information technology, digital technology, and computer science as one of the most fundamental data measurement units.
      </p>

      <div class="p-5 rounded-2xl bg-gradient-to-r from-amber-50 via-orange-50 to-yellow-50 border-l-4 border-amber-500 mb-6">
        <p class="text-gray-700">
          <strong>1 Byte = 8 bits</strong>, which means 1 bit = (1/8) bytes or 0.125 bytes.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 mb-6">
        <div class="p-5 rounded-2xl bg-gradient-to-br from-amber-50 to-white border border-amber-100">
          <h3 class="font-semibold text-gray-900 mb-2">Byte Size Reference</h3>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">•</span>
              <span>1 Kilobyte (KB) = 1,000 Bytes</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">•</span>
              <span>1 Megabyte (MB) = 1,000,000 Bytes</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-1">•</span>
              <span>1 Gigabyte (GB) = 1,000,000,000 Bytes</span>
            </li>
          </ul>
        </div>
        <div class="p-5 rounded-2xl bg-gradient-to-br from-orange-50 to-white border border-orange-100">
          <h3 class="font-semibold text-gray-900 mb-2">Used For</h3>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-orange-500 mt-1">•</span>
              <span>Digital information storage</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-orange-500 mt-1">•</span>
              <span>File size measurement</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-orange-500 mt-1">•</span>
              <span>Data processing & transmission</span>
            </li>
          </ul>
        </div>
      </div>

      <p class="text-gray-600 leading-relaxed">
        The earliest computers used processors supporting 1 byte commands because 1 byte can represent 256 different values (2<sup>8</sup> = 256), making it ideal for encoding characters and basic data units during storage, processing, and transmission of digital information.
      </p>
    </div>
  </article>

  <!-- How Many Bytes in a Megabit Section -->
  <article class="premium-card mt-8">
    <div class="premium-card-inner">
      <h2 class="font-bold text-2xl text-gray-900 mb-6">How Many Bytes in a Megabit?</h2>

      <div class="p-6 rounded-2xl bg-gradient-to-r from-indigo-50 via-purple-50 to-pink-50 border-l-4 border-indigo-500 mb-8">
        <p class="text-lg text-gray-700">
          There are <strong class="text-indigo-600 text-xl">125,000 Bytes</strong> in 1 Megabit.
        </p>
        <p class="text-gray-500 text-sm mt-2">
          1 Megabit = (1/8) × 10<sup>6</sup> Bytes = 125,000 Bytes (B)
        </p>
      </div>

      <h3 class="font-semibold text-gray-900 mb-4">Megabit to Bytes Conversion Formula</h3>
      <p class="text-gray-600 leading-relaxed mb-4">To convert Megabits (Mbit) to Bytes (B), divide the number of bits by 8 because each byte contains 8 bits:</p>

      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        <div class="p-4 rounded-2xl bg-gradient-to-br from-teal-50 to-white border border-teal-100">
          <code class="text-teal-700 text-sm font-semibold">1 Megabit = 1,000,000 bits</code>
        </div>
        <div class="p-4 rounded-2xl bg-gradient-to-br from-amber-50 to-white border border-amber-100">
          <code class="text-amber-700 text-sm font-semibold">1,000,000 ÷ 8 = 125,000 Bytes</code>
        </div>
      </div>

      <h3 class="font-semibold text-gray-900 mb-4">Step-by-Step Calculation</h3>
      <div class="space-y-3 mb-6">
        <div class="flex gap-3 items-start">
          <span class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 font-bold text-sm flex items-center justify-center flex-shrink-0">1</span>
          <span class="text-gray-600">1 Megabit = 10<sup>6</sup> bits = 1,000,000 bits</span>
        </div>
        <div class="flex gap-3 items-start">
          <span class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 font-bold text-sm flex items-center justify-center flex-shrink-0">2</span>
          <span class="text-gray-600">1 Byte = 8 bits, therefore divide by 8</span>
        </div>
        <div class="flex gap-3 items-start">
          <span class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 font-bold text-sm flex items-center justify-center flex-shrink-0">3</span>
          <span class="text-gray-600">1,000,000 bits ÷ 8 = <strong class="text-indigo-600">125,000 Bytes</strong></span>
        </div>
      </div>

      <div class="overflow-x-auto rounded-2xl border border-gray-100 shadow-sm">
        <table class="luxury-table">
          <caption class="sr-only">Megabit to Bytes conversion reference</caption>
          <thead>
            <tr>
              <th>Megabits (Mbit)</th>
              <th>Bits</th>
              <th>Bytes (B)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="text-teal-600 font-semibold">1 Mbit</td>
              <td class="text-gray-600">1,000,000</td>
              <td class="text-amber-600 font-bold">125,000 B</td>
            </tr>
            <tr>
              <td class="text-teal-600 font-semibold">10 Mbit</td>
              <td class="text-gray-600">10,000,000</td>
              <td class="text-amber-600">1,250,000 B</td>
            </tr>
            <tr>
              <td class="text-teal-600 font-semibold">100 Mbit</td>
              <td class="text-gray-600">100,000,000</td>
              <td class="text-amber-600">12,500,000 B</td>
            </tr>
            <tr>
              <td class="text-teal-600 font-semibold">1000 Mbit</td>
              <td class="text-gray-600">1,000,000,000</td>
              <td class="text-amber-600">125,000,000 B</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </article>

  <!-- Mbit to Bytes Conversion Table -->
  <section class="premium-card mt-8">
    <div class="premium-card-inner">
      <div class="flex md:flex-row flex-col md:justify-between md:items-center gap-4 mb-8">
        <h2 class="font-bold text-2xl text-gray-900">Mbit to Bytes Conversion Table</h2>
        <p class="text-gray-400 text-sm font-medium">
          Formula: <span class="text-gray-600">Bytes = Megabits × 125,000</span>
        </p>
      </div>

      <div class="gap-8 grid md:grid-cols-2">
        <div>
          <h3 class="mb-4 font-semibold text-gray-700">Mbps to Bytes per Second</h3>
          <div class="rounded-2xl border border-gray-100 overflow-x-auto shadow-sm">
            <table class="luxury-table">
              <thead>
                <tr>
                  <th>Mbps</th>
