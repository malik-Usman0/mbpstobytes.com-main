  <!-- Calculator Logic -->
  <script is:inline define:vars={{ t }}>
    const BITS_PER_MEGABIT = 1_000_000;
    const BITS_PER_BYTE = 8;

    const el = (id) => document.getElementById(id);
    const $mbps = el("mbps");
    const $bytes = el("bytes");
    const $byteUnit = el("byte-unit");
    const $stdSi = el("std-si");
    const $stdIec = el("std-iec");
    const $stdHint = el("std-hint");
    const $decMinus = el("dec-minus");
    const $decPlus = el("dec-plus");
    const $decValue = el("dec-value");
    const $btnShare = el("btn-share");
    const $btnReload = el("btn-reload");
    const $btnClear = el("btn-clear");

    const $resMain = el("result-main");
    const $resSecondary = el("result-secondary");
    const $resMbps = el("result-mbps");
    const $resBps = el("result-bps");
    const $resKBps = el("result-kbps");
    const $resMBps = el("result-mBps");

    let state = { mbps: "", bytes: "", byteUnit: "B", standard: "si", decimals: 2, lastEdited: "mbps", dirty: false };

    const UNIT_POWERS = { B: 0, KB: 1, MB: 2, GB: 3 };
    const SI_LABELS = { B: "B/s", KB: "KB/s", MB: "MB/s", GB: "GB/s" };
    const IEC_LABELS = { B: "B/s", KB: "KiB/s", MB: "MiB/s", GB: "GiB/s" };

    const unitBase = () => (state.standard === "iec" ? 1024 : 1000);
    const unitFactor = () => Math.pow(unitBase(), UNIT_POWERS[state.byteUnit]);
    const unitLabel = () => (state.standard === "iec" ? IEC_LABELS : SI_LABELS)[state.byteUnit];
    const kLabel = () => (state.standard === "iec" ? "KiB/s:" : t["KB/s:"]);
    const mbLabel = () => (state.standard === "iec" ? "MiB/s:" : t["MB/s:"]);

    const num = (x) => Number(String(x).replace(/[^0-9+\-.e]/g, ""));
    const format = (n) => {
      if (!Number.isFinite(n)) return "";
      return Number(n.toFixed(state.decimals)).toLocaleString();
    };

    const setDirty = (v = true) => {
      state.dirty = v;
      $btnClear.disabled = !v;
      $btnClear.className = v ? "btn-premium btn-danger flex justify-center items-center" : "btn-premium btn-ghost opacity-50 cursor-not-allowed";
    };

    const toBytesPerSecondFromMbps = (mbps) => (mbps * BITS_PER_MEGABIT) / BITS_PER_BYTE;
    const toMbpsFromBytesPerSecond = (bytesPerSecond) => (bytesPerSecond * BITS_PER_BYTE) / BITS_PER_MEGABIT;

    // Raw B/s derived from whichever side was edited last (byte side is in the selected unit)
    const currentRawBps = () => {
      if (state.lastEdited === "mbps") {
        const m = num(state.mbps);
        return Number.isFinite(m) && state.mbps !== "" ? toBytesPerSecondFromMbps(m) : NaN;
      }
      const b = num(state.bytes);
      return Number.isFinite(b) && state.bytes !== "" ? b * unitFactor() : NaN;
    };

    const updateSidebar = () => {
      const rawBps = currentRawBps();

      if (!Number.isFinite(rawBps)) {
        $resMain.textContent = "—";
        $resSecondary.textContent = "";
        [$resMbps, $resBps, $resKBps, $resMBps].forEach((el, i) => {
          const labels = [t["Mbps:"], t["Bytes/s:"], kLabel(), mbLabel()];
          el.innerHTML = `<span class="text-gray-400 text-sm font-medium">${labels[i]}</span><span class="text-gray-600 font-semibold">—</span>`;
        });
        return;
      }

      const mbps = toMbpsFromBytesPerSecond(rawBps);
      const base = unitBase();
      const kBps = rawBps / base;
      const MBps = rawBps / (base * base);
      const unitVal = rawBps / unitFactor();

      const mTxt = format(mbps);
      const bTxt = format(rawBps);
      const kTxt = format(kBps);
      const MBTxt = format(MBps);
      const uTxt = format(unitVal);
      const uLbl = unitLabel();
      const mbLbl = mbLabel().replace(":", "");

      $resMain.textContent = state.lastEdited === "mbps" ? mTxt + " Mbps" : uTxt + " " + uLbl;
      $resSecondary.textContent = state.lastEdited === "mbps" ? uTxt + " " + uLbl + " (≈ " + MBTxt + " " + mbLbl + ")" : mTxt + " Mbps (≈ " + MBTxt + " " + mbLbl + ")";

      $resMbps.innerHTML = `<span class="text-gray-400 text-sm font-medium">${t["Mbps:"]}</span><span class="text-teal-600 font-semibold">${mTxt || "—"}</span>`;
      $resBps.innerHTML = `<span class="text-gray-400 text-sm font-medium">${t["Bytes/s:"]}</span><span class="text-amber-600 font-semibold">${bTxt || "—"}</span>`;
      $resKBps.innerHTML = `<span class="text-gray-400 text-sm font-medium">${kLabel()}</span><span class="text-gray-600 font-semibold">${kTxt || "—"}</span>`;
      $resMBps.innerHTML = `<span class="text-gray-400 text-sm font-medium">${mbLabel()}</span><span class="text-gray-600 font-semibold">${MBTxt || "—"}</span>`;
    };

    const updateNumbers = () => {
      if (state.lastEdited === "mbps") {
        const m = num(state.mbps);
        if (!Number.isFinite(m) || state.mbps === "") {
          state.bytes = "";
          $bytes.value = "";
        } else {
          const unitVal = toBytesPerSecondFromMbps(m) / unitFactor();
          const bFmt = Number(unitVal.toFixed(Math.max(state.decimals, 6))).toString();
          state.bytes = bFmt;
          $bytes.value = bFmt;
        }
      } else {
        const b = num(state.bytes);
        if (!Number.isFinite(b) || state.bytes === "") {
          state.mbps = "";
          $mbps.value = "";
        } else {
          const mbps = toMbpsFromBytesPerSecond(b * unitFactor());
          const mFmt = Number(mbps.toFixed(Math.max(state.decimals, 6))).toString();
          state.mbps = mFmt;
          $mbps.value = mFmt;
        }
      }
      updateSidebar();
      $decValue.textContent = state.decimals;
    };

    const refreshStandardUI = () => {
      const si = state.standard === "si";
      $stdSi.className = si ? "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200" : "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdIec.className = !si ? "px-4 py-1.5 rounded-lg text-sm font-semibold bg-white text-indigo-600 shadow-sm transition-all duration-200" : "px-4 py-1.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200";
      $stdSi.setAttribute("aria-pressed", String(si));
      $stdIec.setAttribute("aria-pressed", String(!si));
      $stdHint.textContent = si ? "1 KB = 1,000 B · 1 MB = 1,000,000 B" : "1 KiB = 1,024 B · 1 MiB = 1,048,576 B";
      const labels = si ? SI_LABELS : IEC_LABELS;
      [...$byteUnit.options].forEach((opt) => (opt.textContent = labels[opt.value]));
    };

    const setStandard = (std) => {
      state.standard = std;
      refreshStandardUI();
      updateNumbers();
    };

    const clearAll = () => {
      const std = state.standard;
      const unit = state.byteUnit;
      state = { mbps: "", bytes: "", byteUnit: unit, standard: std, decimals: 2, lastEdited: "mbps", dirty: false };
      $mbps.value = "";
      $bytes.value = "";
      $decValue.textContent = state.decimals;
      updateSidebar();
      setDirty(false);
      updateVisualization(0, 0);
    };

    const shareText = async () => {
      const rawBps = currentRawBps();
      if (!Number.isFinite(rawBps)) return;
      const mbps = toMbpsFromBytesPerSecond(rawBps);
      const base = unitBase();
      const MBTxt = format(rawBps / (base * base));
      const mbLbl = mbLabel().replace(":", "");
      const txt = `Mbps↔Bytes/s: ${format(mbps)} Mbps = ${format(rawBps)} B/s (≈ ${MBTxt} ${mbLbl}). via mbpstobytes.com`;
      try {
        await navigator.clipboard.writeText(txt);
      } catch (e) {}
    };

    const refreshVisualization = () => {
      const rawBps = currentRawBps();
      if (!Number.isFinite(rawBps)) {
        updateVisualization(0, 0);
        return;
      }
      updateVisualization(toMbpsFromBytesPerSecond(rawBps), rawBps);
    };

    $mbps.addEventListener("input", () => {
      state.mbps = $mbps.value;
      state.lastEdited = "mbps";
      setDirty(true);
      updateNumbers();
      refreshVisualization();
    });

    $bytes.addEventListener("input", () => {
      state.bytes = $bytes.value;
      state.lastEdited = "bytes";
      setDirty(true);
      updateNumbers();
      refreshVisualization();
    });

    $byteUnit.addEventListener("change", () => {
      state.byteUnit = $byteUnit.value;
      updateNumbers();
      refreshVisualization();
    });

    $stdSi.addEventListener("click", () => setStandard("si"));
    $stdIec.addEventListener("click", () => setStandard("iec"));

    $decMinus.addEventListener("click", () => {
      state.decimals = Math.max(0, state.decimals - 1);
      updateNumbers();
    });
    $decPlus.addEventListener("click", () => {
      state.decimals = Math.min(10, state.decimals + 1);
      updateNumbers();
    });
    $btnShare.addEventListener("click", shareText);
    $btnReload.addEventListener("click", () => window.location.reload());
    $btnClear.addEventListener("click", clearAll);

    (function init() {
      refreshStandardUI();
      updateSidebar();
      setDirty(false);
    })();
  </script>

  <!-- Visualization Script -->
  <script is:inline>
    const vizContainer = document.getElementById("conversion-viz");
    const canvas = document.getElementById("particle-canvas");
    const ctx = canvas ? canvas.getContext("2d") : null;
    const bitBoxes = document.querySelectorAll(".bit-box");
    const byteBox = document.getElementById("byte-result");
    const mbpsDisplayViz = document.getElementById("mbps-display");
    const bytesDisplayViz = document.getElementById("bytes-display");
    const speedBar = document.getElementById("speed-bar");

    let particles = [];
    let animationSpeed = 1;
    let isConverting = false;

    function resizeCanvas() {
      if (!canvas || !vizContainer) return;
      canvas.width = vizContainer.offsetWidth;
      canvas.height = vizContainer.offsetHeight;
    }

    class Particle {
      constructor() {
        this.reset();
      }
      reset() {
        this.x = canvas.width * 0.12;
        this.y = canvas.height / 2 + (Math.random() - 0.5) * 40;
        this.vx = (3 + Math.random() * 2) * animationSpeed;
        this.size = 4 + Math.random() * 3;
        this.progress = 0;
      }
      update() {
        this.x += this.vx;
        this.progress = (this.x - canvas.width * 0.12) / (canvas.width * 0.76);
        if (this.progress > 0.7) this.size *= 0.97;
        if (this.x > canvas.width * 0.88) this.reset();
      }
      draw() {
        if (!ctx) return;
        const t = Math.min(1, this.progress);
        // Teal to Amber transition
        const r = Math.round(20 + (245 - 20) * t);
        const g = Math.round(184 + (158 - 184) * t);
        const b = Math.round(166 + (11 - 166) * t);
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.9)`;
        ctx.shadowColor = `rgba(${r}, ${g}, ${b}, 0.5)`;
        ctx.shadowBlur = 12;
        ctx.fill();
        ctx.shadowBlur = 0;
      }
    }

    function animate() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      if (isConverting && particles.length < 15) particles.push(new Particle());
      particles.forEach((p) => {
        p.update();
        p.draw();
      });

      if (isConverting) {
        bitBoxes.forEach((box, i) => {
          const phase = (Date.now() / 150 + i) % 8;
          box.classList.toggle("active", phase < 1);
          box.textContent = Math.random() > 0.5 ? "1" : "0";
        });
        byteBox.classList.add("active");
      } else {
        bitBoxes.forEach((box) => box.classList.remove("active"));
        byteBox.classList.remove("active");
      }

      requestAnimationFrame(animate);
    }

    window.updateVisualization = function (mbpsValue, bytesValue) {
      const mbps = parseFloat(mbpsValue) || 0;
      const bytes = parseFloat(bytesValue) || 0;

      if (mbpsDisplayViz) mbpsDisplayViz.textContent = mbps.toLocaleString();
      if (bytesDisplayViz) bytesDisplayViz.textContent = Math.round(bytes).toLocaleString();

      const speedPercent = Math.min(100, (mbps / 1000) * 100);
      if (speedBar) speedBar.style.width = speedPercent + "%";

      animationSpeed = Math.max(0.5, Math.min(4, mbps / 50));
      isConverting = mbps > 0 || bytes > 0;

      if (vizContainer) {
        vizContainer.classList.toggle("converting", isConverting);
        if (!isConverting) particles = [];
      }
    };

    window.addEventListener("resize", resizeCanvas);
    resizeCanvas();
    animate();
  </script>

