---
import Layout from '@theme/layouts/Layout.astro';
import { getTranslations } from '../i18n/utils';

const { site_title } = getTranslations();
---

<Layout title={`404 - Not Found | ${site_title}`} description="The page you are looking for does not exist.">
  <h1 class="font-semibold text-slate-800 text-5xl text-center">404</h1>

  <p class="mt-5 text-xl text-center">The page you are looking for does not exist.</p>

  <a href="/" class="block mt-4 text-sky-600 text-xl text-center hover:underline">Go to homepage</a>
</Layout>
