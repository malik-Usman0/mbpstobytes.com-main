---
import Layout from '@theme/layouts/Layout.astro';
import ContactForm from '@theme/components/ContactForm.astro';

import { getTranslations } from '../i18n/utils';

const { site_title } = getTranslations();
---

<Layout title={`Contact Us | ${site_title}`} description="Questions, corrections, or feedback about our converters and guides? Reach the Mbps to Bytes team — we verify reported errors within 48 hours.">
  <h1 class="font-semibold text-slate-800 text-3xl">Contact Us</h1>
  <p class="mt-2 text-slate-600">We read every message. Fill the form and we will get back to you as soon as possible.</p>
  <ContactForm />
</Layout>
