---
import Layout from '@theme/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

import { getTranslations } from '../i18n/utils';

export interface Props {
  [key: string]: any;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { id: post.id },
  }));
}

// Fetch the entry based on the id param
const posts = await getCollection('blog');
const entry = posts.find((post) => post.id === Astro.params.id);

if (!entry) {
  return Astro.redirect('/404');
}

// Render the blog post content
const { Content } = await render(entry);

const siteURL = Astro.url.origin;
const canonical = `${siteURL}/blog/${entry.id}/`;
const imageUrl = `${siteURL}${entry.data.image}`;

const { site_title } = getTranslations();
---

<Layout img={entry.data.image} title={entry.data.title + ' | ' + site_title} description={entry.data.description}>
  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      mainEntityOfPage: canonical,
      headline: entry.data.title,
      description: entry.data.description,
      url: canonical,
      inLanguage: 'en',
      image: [imageUrl],
      thumbnailUrl: imageUrl,
      author: {
        '@type': 'Organization',
        name: site_title,
        url: `${siteURL}/`,
      },
      publisher: {
        '@type': 'Organization',
        name: site_title,
        url: siteURL,
        logo: {
          '@type': 'ImageObject',
          url: `${siteURL}/images/logo.png`,
        },
      },
    })}
  />

  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: siteURL,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: `${siteURL}/blog/`,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: entry.data.title,
          item: canonical,
        },
      ],
    })}
  />

  <article class="mx-auto px-6 pt-12 max-w-6xl">
    <header class="isolate relative overflow-hidden">
      <div class="md:items-center gap-8 grid md:grid-cols-2">
        <div>
          <h1 class="font-semibold text-slate-900 text-3xl md:text-4xl tracking-tight">{entry.data.title}</h1>
          <p class="mt-4 text-slate-600 leading-relaxed">{entry.data.description}</p>
        </div>
        <div class="relative">
          <div class="relative bg-white shadow-sm rounded-2xl ring-1 ring-slate-200 w-full aspect-[16/10] overflow-hidden">
            <img src={entry.data.image} alt={`Featured image: ${entry.data.title}`} class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" decoding="async" />
          </div>
          <p class="mt-3 text-slate-500 text-xs text-center">Featured image: {entry.data.title}</p>
        </div>
      </div>
    </header>
    <main class="mx-auto px-6 max-w-3xl">
      <Content />
    </main>
  </article>
</Layout>
