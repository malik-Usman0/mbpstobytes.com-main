---
interface Tool {
  name: string;
  url: string;
  description: string;
  icon?: string;
}

interface Props {
  title?: string;
  tools: Tool[];
}

const { title = 'Related Tools', tools } = Astro.props;
---

<section class="mt-12">
  <div class="text-center mb-8">
    <h2 class="font-bold text-2xl text-gray-900">{title}</h2>
    <p class="text-gray-500 text-sm mt-2">More free converters and calculators</p>
  </div>
  <div class={`grid gap-4 sm:grid-cols-2 ${tools.length > 2 ? 'lg:grid-cols-' + Math.min(tools.length, 4) : ''} max-w-4xl mx-auto`}>
    {
      tools.map((tool) => (
        <a href={tool.url} class="premium-card block p-6 group hover:shadow-lg transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg shadow-indigo-200 flex-shrink-0 text-white font-black text-lg">
              {tool.icon ?? '⇄'}
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors duration-300">{tool.name}</h3>
              <p class="text-gray-500 text-sm mt-1 leading-relaxed">{tool.description}</p>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
