---
import { getTranslations, getLocalizedUrl } from "@theme/i18n/utils";
import LanguageSwitcher from "@theme/components/LanguageSwitcher.astro";

import config from "~/config/config.json";
import navigation from "~/config/navigation.json";

import Facebook from "./SVGs/Facebook.astro";
import Linkedin from "./SVGs/Linkedin.astro";
import Twitter from "./SVGs/Twitter.astro";
import Pinterest from "./SVGs/Pinterest.astro";

const locale = Astro.currentLocale;
const t = getTranslations(locale);

const socialLogos: Record<string, any> = {
  facebook: Facebook,
  linkedin: Linkedin,
  twitter: Twitter,
  pinterest: Pinterest,
};

const getSocialLogoMarkup = (name: string) => socialLogos[name.toLowerCase()] ?? null;
---

<footer class="relative mt-20 bg-gradient-to-b from-gray-50 to-white overflow-hidden">
  <!-- Top decorative gradient -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo-200 to-transparent"></div>

  <div class="relative flex flex-col items-center gap-10 mx-auto px-6 py-16 text-center max-w-6xl">
    <!-- Logo & Description -->
    <div class="flex flex-col items-center gap-6">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-3xl blur-2xl opacity-15"></div>
        <img src="/images/logo.png" width="80" height="80" alt={t["Footer Logo"]} loading="lazy" class="relative rounded-2xl" />
      </div>
      <h2 class="font-bold text-2xl text-gray-900">
        {t.site_title}
      </h2>
      <p class="max-w-xl text-gray-500 text-base leading-relaxed">
        {t.footer_description}
      </p>
    </div>

    <!-- Navigation Links -->
    <nav>
      <ul class="flex flex-wrap justify-center gap-3">
        {
          navigation.footer.map((item) => (
            <li>
              <a href={item.url === "/" ? getLocalizedUrl(item.url, locale) : item.url} class="px-4 py-2 rounded-xl text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 text-sm font-medium transition-all duration-300">
                {t[item.name]}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Social Icons -->
    {
      config.social.find((item) => !!item.url) && (
        <div class="flex justify-center gap-3">
          {config.social.map((item) => {
            if (!item.url) return null;
            const IconMarkup = getSocialLogoMarkup(item.name);
            if (!IconMarkup) return null;
            return (
              <a href={item.url} title={item.name + " " + t["Logo"]} class="p-3 rounded-2xl border border-gray-200 bg-white hover:border-indigo-200 hover:bg-indigo-50 transition-all duration-300 group shadow-sm hover:shadow-md">
                <IconMarkup class="w-5 h-5 text-gray-400 group-hover:text-indigo-600 transition-colors duration-300" />
              </a>
            );
          })}
        </div>
      )
    }

    <!-- Language Switcher -->
    <LanguageSwitcher />

    <!-- Copyright -->
    <div class="pt-10 border-t border-gray-100 w-full">
      <p class="text-gray-400 text-sm">
        &copy; {new Date().getFullYear()}
        <span class="text-gray-600 font-medium">{t.site_title}</span>. All rights reserved.
      </p>
    </div>
  </div>
</footer>
