---
import { getTranslations } from '@theme/i18n/utils';
import config from '~/config/config.json';

interface FAQ {
  question: string;
  answer: string;
}

const locale = Astro.currentLocale;
const t = getTranslations(locale);
const faqs = t.faqs ?? [];

const stripHTML = (html: string) => html.replace(/<[^>]+>/g, '');

const siteURL = Astro.url.origin;
---

<>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${siteURL}#website`,
      url: siteURL,
      name: t.site_title,
      headline: t.index_title,
      description: t.index_description,
      inLanguage: locale,
    })}
  />

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      '@id': `${siteURL}#webapplication`,
      name: t.index_title,
      url: siteURL,
      description: t.index_description,
      applicationCategory: 'UtilityApplication',
      operatingSystem: 'Any',
      browserRequirements: 'Requires JavaScript',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      ...(config.site.rating_value && config.site.rating_count
        ? {
            aggregateRating: {
              '@type': 'AggregateRating',
              ratingValue: config.site.rating_value,
              ratingCount: config.site.rating_count,
              bestRating: '5',
              worstRating: '1',
            },
          }
        : {}),
      publisher: {
        '@type': 'Organization',
        '@id': `${siteURL}#organization`,
      },
      inLanguage: locale,
    })}
  />

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: 'How to Convert Mbps to Bytes per Second',
      description: 'Convert Megabits per second (Mbps) to Bytes per second (B/s) using the formula Bytes/s = Mbps × 1,000,000 ÷ 8.',
      totalTime: 'PT1M',
      step: [
        { '@type': 'HowToStep', position: 1, name: 'Convert Megabits to bits', text: 'Multiply the Mbps value by 1,000,000 to get bits per second.' },
        { '@type': 'HowToStep', position: 2, name: 'Divide by 8 to get Bytes', text: 'Divide the result by 8, because 1 Byte = 8 bits.' },
        { '@type': 'HowToStep', position: 3, name: 'Read the result', text: 'The result is your data transfer rate in Bytes per second. Example: 100 Mbps = 12,500,000 B/s = 12.5 MB/s.' },
      ],
    })}
  />

  {
    faqs.length > 0 && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faqs.map((faq: FAQ) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: stripHTML(faq.answer),
            },
          })),
        })}
      />
    )
  }
</>
