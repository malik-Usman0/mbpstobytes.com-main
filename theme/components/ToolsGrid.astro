---
import toolsConfig from '~/config/tools.json';

interface Props {
  title?: string;
  subtitle?: string;
  showViewAll?: boolean;
  currentUrl?: string;
}

const { title = 'All Converters & Tools', subtitle = 'Free, real-time data-rate calculators — no ads, no sign-up.', showViewAll = false, currentUrl } = Astro.props;

const categories = toolsConfig.categories
  .map((cat) => ({
    ...cat,
    tools: cat.tools.filter((tool) => tool.url !== currentUrl),
  }))
  .filter((cat) => cat.tools.length > 0);
---

<section class="mt-12">
  <div class="text-center mb-8">
    <h2 class="font-bold text-2xl text-gray-900">{title}</h2>
    <p class="text-gray-500 text-sm mt-2">{subtitle}</p>
  </div>

  {
    categories.map((cat) => (
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-4 max-w-4xl mx-auto">
          <h3 class="font-semibold text-gray-700">{cat.name}</h3>
          <div class="flex-1 h-px bg-gradient-to-r from-gray-200 to-transparent" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2 max-w-4xl mx-auto">
          {cat.tools.map((tool) => (
            <a href={tool.url} class="premium-card block p-6 group hover:shadow-lg transition-all duration-300">
              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg shadow-indigo-200 flex-shrink-0 text-white font-black text-lg">
                  {tool.icon}
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors duration-300">{tool.name}</h4>
                  <p class="text-gray-500 text-sm mt-1 leading-relaxed">{tool.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))
  }

  {
    showViewAll && (
      <div class="text-center mt-6">
        <a href="/converters/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 text-white font-semibold text-sm shadow-lg shadow-indigo-200 hover:opacity-90 transition-opacity duration-300">
          View all converters →
        </a>
      </div>
    )
  }
</section>
