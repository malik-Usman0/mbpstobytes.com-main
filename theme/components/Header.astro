---
import { getTranslations, getLocalizedUrl } from "@theme/i18n/utils";
import navigation from "~/config/navigation.json";

const locale = Astro.currentLocale;
const t = getTranslations(locale);

const siteTitle = t.site_title;
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-2xl border-b border-gray-100">
  <div class="flex justify-between items-center mx-auto px-6 py-5 max-w-6xl">
    <a aria-label={`${siteTitle} ${t["Home"]}`} class="flex flex-1 items-center gap-4 group" href={getLocalizedUrl("/", locale)}>
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-2xl blur-lg opacity-20 group-hover:opacity-40 transition-opacity duration-500"></div>
        <img src="/images/logo.png" width="48" height="48" alt={`${siteTitle} ${t["Logo"]}`} loading="eager" class="relative z-10 rounded-xl" />
      </div>
      <div class="leading-tight">
        <span class="block font-bold text-xl text-gray-900 group-hover:text-indigo-600 transition-colors duration-300">
          {siteTitle}
        </span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-2" aria-label="Primary">
      {
        navigation.header.map((item) => (
          <a class="px-4 py-2 rounded-xl text-gray-600 hover:text-indigo-600 hover:bg-indigo-50 text-sm font-semibold transition-all duration-300" href={item.url === "/" ? getLocalizedUrl(item.url, locale) : item.url}>
            {t[item.name] ?? item.name}
          </a>
        ))
      }
    </nav>

    <!-- Mobile button -->
    <div class="lg:hidden">
      <button type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" class="p-3 border border-gray-200 rounded-xl bg-white hover:bg-indigo-50 hover:border-indigo-200 transition-all duration-300" id="mobile-menu-toggle">
        <svg class="w-5 h-5 text-gray-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </div>

</header>

<!-- Mobile menu (must live OUTSIDE <header>: its backdrop-filter creates a containing block that traps position:fixed descendants) -->
  <!-- Mobile menu -->
  <div id="mobile-menu" role="dialog" aria-modal="true" aria-hidden="true" inert class="lg:hidden z-50 fixed inset-0 transition-transform -translate-y-full duration-300 ease-in-out transform">
    <div class="absolute inset-0 bg-white p-6 overflow-auto">
      <div class="flex justify-between items-center mb-10">
        <div class="flex items-center gap-3">
          <img src="/images/logo.png" width="48" height="48" alt={`${siteTitle} ${t["Logo"]}`} loading="eager" class="rounded-xl" />
          <div class="leading-tight">
            <a class="font-bold text-xl text-gray-900" href={getLocalizedUrl("/", locale)} id="mobile-home-link">
              {siteTitle}
            </a>
          </div>
        </div>
        <button type="button" class="p-3 border border-gray-200 rounded-xl bg-white hover:bg-gray-50 transition-all duration-300" aria-label="Close menu" id="mobile-menu-close">
          <svg class="w-5 h-5 text-gray-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M6 18L18 6M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>

      <nav class="flex flex-col gap-2" aria-label="Mobile">
        {
          navigation.header.map((item) => (
            <a class="px-5 py-4 rounded-2xl text-gray-600 hover:text-indigo-600 hover:bg-indigo-50 font-semibold text-lg mobile-nav-link transition-all duration-300" href={item.url === "/" ? getLocalizedUrl(item.url, locale) : item.url}>
              {t[item.name] ?? item.name}
            </a>
          ))
        }
      </nav>
    </div>
  </div>


<script is:inline type="text/javascript">
  const btn = document.getElementById("mobile-menu-toggle");
  const closeBtn = document.getElementById("mobile-menu-close");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");
  const homeLink = document.getElementById("mobile-home-link");

  const openMenu = () => {
    mobileMenu.classList.remove("-translate-y-full");
    mobileMenu.classList.add("translate-y-0");
    mobileMenu.setAttribute("aria-hidden", "false");
    mobileMenu.removeAttribute("inert");
    btn.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  const closeMenu = () => {
    mobileMenu.classList.remove("translate-y-0");
    mobileMenu.classList.add("-translate-y-full");
    mobileMenu.setAttribute("aria-hidden", "true");
    mobileMenu.setAttribute("inert", "");
    btn.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  if (btn && mobileMenu) {
    btn.addEventListener("click", () => {
      const isOpen = mobileMenu.getAttribute("aria-hidden") === "false";
      if (isOpen) closeMenu();
      else openMenu();
    });
  }

  if (closeBtn) closeBtn.addEventListener("click", closeMenu);
  [...mobileLinks, homeLink].forEach((el) => {
    if (el) el.addEventListener("click", closeMenu);
  });
</script>
